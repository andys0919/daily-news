---
import Base from "../layouts/Base.astro";
import overview from "../data/overview.json";

interface Theme { theme: string; count: number; examples: any[] }
const themes = (overview.themes ?? []) as Theme[];
const total = themes.reduce((a, t) => a + t.count, 0);

function ago(iso: string | undefined): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  const h = Math.floor((Date.now() - d.getTime()) / 3.6e6);
  if (h < 24) return `${h}h`;
  return `${Math.floor(h / 24)}d`;
}
---
<Base title="主題熱度 — 30 天追蹤" active="themes">
  <section class="hero">
    <div>
      <span class="live"><span class="live-dot"></span>{themes.length} themes · {total} mentions</span>
      <h1 class="mt-2">主題 <span class="accent">熱度</span></h1>
      <p class="hero-sub">關鍵字聚類，從近 30 天 15,000+ 篇新聞中萃取出來的主題流量。點任一卡片可看代表文章。</p>
    </div>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {themes.map((t, i) => (
      <article id={t.theme} class="glass bento">
        <header class="bento-head">
          <h2 class="bento-title">{t.theme}</h2>
          <span class={`bento-link mono ${i < 3 ? "" : ""}`} style={i < 3 ? "color: var(--warn);" : ""}>
            {t.count} 篇 · {total > 0 ? ((t.count / total) * 100).toFixed(1) : 0}%
          </span>
        </header>
        <div class="bar" style="margin: 4px 0 14px; height:6px; border-radius:999px; background: var(--bg-700); overflow:hidden;">
          <div class="bar-fill" style={`width:${Math.min(100, (t.count / Math.max(1, themes[0].count)) * 100)}%; height:100%; background: linear-gradient(90deg, var(--accent), var(--accent-strong)); border-radius:999px;`}></div>
        </div>
        <div class="trx">
          {(t.examples ?? []).slice(0, 5).map((e: any) => (
            <div class="trx-item">
              <div class="trx-stamp">{ago(e.published)}</div>
              <div class="trx-body">
                <div class="h">
                  <a href={e.link} target="_blank" rel="noopener"><strong>{e.title}</strong></a>
                </div>
                <p class="muted-2 mono" style="font-size:11px; margin-top:2px;">
                  {e.source}{e.tickers?.length > 0 ? ` · ${e.tickers.slice(0, 3).join(", ")}` : ""}
                </p>
              </div>
            </div>
          ))}
          {(t.examples ?? []).length === 0 && <p class="muted text-sm">（暫無代表文章）</p>}
        </div>
      </article>
    ))}
  </section>
</Base>
