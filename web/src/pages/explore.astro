---
import Base from "../layouts/Base.astro";
import overview from "../data/overview.json";

interface Mention { ticker: string; mentions: number; last_seen: string }
interface Theme { theme: string; count: number; examples: any[] }

const topTickers7 = (overview.top_tickers_7d ?? []) as Mention[];
const themes = (overview.themes ?? []) as Theme[];
const velocity = overview.velocity ?? { days: [], totals: [], by_category: {} };
const categories = (overview.categories ?? []) as { category: string; count: number; pct: number }[];

const days = (velocity.days ?? []) as string[];
const totals = (velocity.totals ?? []) as number[];
const maxTotal = Math.max(1, ...totals);
const w = 320, h = 60, pad = 6;
const stepX = days.length > 1 ? (w - 2 * pad) / (days.length - 1) : 0;
const pts = totals.map((v, i) => `${pad + i * stepX},${h - pad - (v / maxTotal) * (h - 2 * pad)}`);
const areaPath = pts.length > 0 ? `M${pts[0]} L${pts.join(" L")} L${pad + (totals.length - 1) * stepX},${h - pad} L${pad},${h - pad} Z` : "";
const linePath = pts.length > 0 ? `M${pts.join(" L")}` : "";

const catRows = categories.slice(0, 8);
const maxCat = catRows.length > 0 ? Math.max(...catRows.map((c) => c.count)) : 1;
---
<Base title="Explore — 探索式視角 (lagging signals)" active="explore">
  <section class="hero">
    <div>
      <span class="live" style="background: rgba(255, 174, 92, 0.08); border-color: rgba(255, 174, 92, 0.3);"><span class="live-dot" style="background: var(--warn); box-shadow: 0 0 6px var(--warn);"></span>vanity / lagging</span>
      <h1 class="mt-2">探索 <span class="accent">視角</span></h1>
      <p class="hero-sub">
        本頁所有指標都是 <strong style="color: var(--warn);">lagging</strong> 與 vanity——
        提及量、velocity、分類流量、主題標籤都只反映「新聞編輯部當下的注意力」，<strong>不是投資訊號</strong>。
        放在這裡只供 pipeline 健康度檢視與題材探索用。實際決策訊號請見 <a href="/" style="text-decoration: underline; color: var(--accent-strong);">首頁 Guidance Feed</a> 與
        <a href="/guidance" style="text-decoration: underline; color: var(--accent-strong);">/guidance</a>。
      </p>
    </div>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">News velocity · 14 天 (pipeline 健康)</h2>
        <span class="bento-link mono">avg {Math.round(totals.reduce((a, b) => a + b, 0) / Math.max(1, totals.length))}/day</span>
      </header>
      <svg class="spark" viewBox={`0 0 ${w} ${h}`} preserveAspectRatio="none">
        <path class="area" d={areaPath} />
        <path class="line" d={linePath} />
        {pts.map((p) => {
          const [x, y] = p.split(",").map(Number);
          return <circle class="dot" cx={x} cy={y} r="2" />;
        })}
      </svg>
      <div style="display:flex; justify-content:space-between; margin-top:6px;">
        <span class="muted-2 mono" style="font-size:10px;">{days[0] ?? ""}</span>
        <span class="muted-2 mono" style="font-size:10px;">{days[days.length - 1] ?? ""}</span>
      </div>
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">Top mentions · 7d (lagging)</h2>
        <span class="bento-link mono">{topTickers7.length}</span>
      </header>
      <div class="lb">
        {topTickers7.slice(0, 10).map((t, i) => (
          <a class="lb-row" href={`/stocks/${t.ticker}`}>
            <span class="rank mono">#{(i + 1).toString().padStart(2, "0")}</span>
            <span class="name mono"><strong>{t.ticker}</strong></span>
            <span class="v">{t.mentions} 篇</span>
            <span class="delta flat mono">{t.last_seen}</span>
          </a>
        ))}
      </div>
    </article>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">分類流量 · pipeline 結構</h2>
      </header>
      {catRows.map((c) => (
        <div class="cat-row">
          <div class="lbl" style="min-width:0;">
            <div class="lbl-text">{c.category}</div>
            <div class="bar"><div class="bar-fill" style={`width:${Math.max(2, (c.count / maxCat) * 100)}%`}></div></div>
          </div>
          <span class="v">{c.count} · {c.pct}%</span>
        </div>
      ))}
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">主題標籤 · keyword counts</h2>
        <a href="/themes" class="bento-link">細節 →</a>
      </header>
      <div class="theme-cloud">
        {themes.slice(0, 12).map((t) => (
          <a href={`/themes#${encodeURIComponent(t.theme)}`} class="theme-chip">
            <span>{t.theme}</span>
            <span class="n">{t.count}</span>
          </a>
        ))}
      </div>
    </article>
  </section>
</Base>
