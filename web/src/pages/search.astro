---
import Base from "../layouts/Base.astro";
import tickerIndex from "../data/tickers.json";

interface Row { ticker: string; name: string; market: string; articles: number; reports: number }
const all = (tickerIndex.tickers ?? []) as Row[];
const tw = all.filter((r) => r.market === "tw");
const us = all.filter((r) => r.market === "us");
---
<Base title="個股 — 投資 dashboard" active="search">
  <header class="page-h">
    <div class="eyebrow">{all.length} 檔個股 · 台股 {tw.length} · 美股 {us.length}</div>
    <h1>查詢 <span class="accent">個股</span></h1>
    <p>
      上方搜尋框可即時搜 ticker 或公司名（如 <span class="mono">2330</span> / <span class="mono">NVDA</span> / 台積電）。下面是完整清單，依新聞活躍度排序。點任一檔進入個股頁查看健康度、重點新聞、財報歷史。
    </p>
  </header>

  <aside class="howto">
    <div class="howto-icon">i</div>
    <div>
      <p class="howto-title">怎麼讀清單</p>
      <p class="howto-body">
        每張卡片顯示 <strong>ticker + 公司名 + 新聞篇數 (A) + 官方財報份數 (R)</strong>。<strong>A 多</strong>表示這檔近 30 天新聞活躍度高；<strong>R 多</strong>表示有官方財報深度（適合做基本面分析）。用上方按鈕切台美股，或鍵盤按 <kbd class="kbd">/</kbd> 開啟搜尋框。
      </p>
    </div>
  </aside>

  <div class="filters" id="filter-bar">
    <button class="fbtn" data-market="" data-active="true">全部 · {all.length}</button>
    <button class="fbtn" data-market="us">🇺🇸 美股 · {us.length}</button>
    <button class="fbtn" data-market="tw">🇹🇼 台股 · {tw.length}</button>
  </div>

  <div class="cov-grid" id="ticker-grid">
    {all.map((r) => (
      <a href={`/stocks/${r.ticker}/`} class="cov-cell" data-market={r.market}>
        <span class="t">{r.ticker}</span>
        {r.name && <span class="meta line-clamp-1" style="color: var(--fg-300); font-size: var(--t-label); font-family: 'IBM Plex Sans', sans-serif;">{r.name}</span>}
        <span class="meta" style="margin-top: var(--s-1);">
          {r.articles > 0 && <><span class="dot a"></span>{r.articles}A </>}
          {r.reports > 0 && <><span class="dot r"></span>{r.reports}R</>}
        </span>
      </a>
    ))}
  </div>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const bar = document.getElementById("filter-bar");
      const cells = Array.from(document.querySelectorAll("#ticker-grid .cov-cell"));
      if (!bar) return;
      bar.addEventListener("click", (e) => {
        const t = e.target;
        if (!(t instanceof HTMLElement) || !t.matches(".fbtn")) return;
        const want = t.getAttribute("data-market") || "";
        bar.querySelectorAll(".fbtn").forEach((b) => b.removeAttribute("data-active"));
        t.setAttribute("data-active", "true");
        cells.forEach((c) => {
          const m = c.getAttribute("data-market") || "";
          c.style.display = !want || m === want ? "" : "none";
        });
      });
    });
  </script>
</Base>
