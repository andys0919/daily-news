---
import Base from "../layouts/Base.astro";
import events from "../data/events.json";

interface Event { kind: string; title: string; date: string; source: string; link: string | null; tickers: string[]; category: string; }

const list = (events.events ?? []) as unknown as Event[];
const byDate = list.reduce((acc: Record<string, Event[]>, e) => {
  if (!e.date) return acc;
  (acc[e.date] = acc[e.date] || []).push(e);
  return acc;
}, {});
const dates = Object.keys(byDate).sort().reverse();
const kindCounts: Record<string, number> = {};
list.forEach((e) => { kindCounts[e.kind] = (kindCounts[e.kind] || 0) + 1; });
const kindLabels: Record<string, string> = { earnings: "Earnings", capex: "Capex", policy: "Policy", filing: "Filing" };
---
<Base title="事件 — 投資 dashboard" active="calendar">
  <header class="page-h">
    <div class="eyebrow">30 days · {list.length} 事件</div>
    <h1>事件 <span class="accent">月曆</span></h1>
    <p>
      Daily-news pipeline 在文章上標的事件性新聞，按日期反向排列。<strong>Earnings</strong>=財報相關，<strong>Capex</strong>=資本支出/擴產，<strong>Policy</strong>=政策/監管，<strong>Filing</strong>=正式文件。
    </p>
    <div class="meta">
      {Object.entries(kindCounts).map(([k, n]) => (
        <div><span class={`evt-badge ${k}`}>{kindLabels[k] || k}</span> <strong>{n}</strong></div>
      ))}
    </div>
  </header>

  <aside class="howto">
    <div class="howto-icon">i</div>
    <div>
      <p class="howto-title">怎麼用這頁</p>
      <p class="howto-body">
        <strong>篩選按鈕</strong>只看特定類型事件（如只看 capex）。<strong>日期</strong>分組，最近的在上。每條事件顯示來源 + 影響的 ticker chip，點 chip 跳個股頁。<strong>注意</strong>：這裡的事件分類是從 RSS 標題 keyword 推得，不是公司官方排程；要看官方法說行程需另查 IR 網站。
      </p>
    </div>
  </aside>

  <div class="filters" id="filter-bar">
    <button class="fbtn" data-kind="" data-active="true">全部 · {list.length}</button>
    {Object.entries(kindCounts).map(([k, n]) => (
      <button class="fbtn" data-kind={k}>{kindLabels[k] || k} · {n}</button>
    ))}
  </div>

  {dates.length === 0 ? (
    <p class="muted" style="padding: var(--s-6);">尚無事件資料。</p>
  ) : (
    <div id="cal" style="display: flex; flex-direction: column; gap: var(--s-4);">
      {dates.map((d) => (
        <article class="glass bento" data-date={d}>
          <header class="bento-head" style="margin-bottom: var(--s-3);">
            <h2 class="bento-title mono">{d}</h2>
            <span class="bento-link mono">{byDate[d].length} 筆</span>
          </header>
          <ul style="display: flex; flex-direction: column; gap: var(--s-1);">
            {byDate[d].map((e) => (
              <li class="cal-row" data-kind={e.kind} style="display: grid; grid-template-columns: 80px 1fr auto; gap: var(--s-3); padding: var(--s-2) 0; border-bottom: 1px solid var(--border-base); align-items: baseline;">
                <span class={`evt-badge ${e.kind}`}>{kindLabels[e.kind] || e.kind}</span>
                {e.link ? (
                  <a href={e.link} target="_blank" rel="noopener" style="font-size: var(--t-body); color: var(--fg-100);">
                    <span class="line-clamp-1">{e.title}</span>
                    <span class="muted-2 mono" style="display: block; font-size: var(--t-label); margin-top: var(--s-1);">{e.source}</span>
                  </a>
                ) : (
                  <div style="font-size: var(--t-body); color: var(--fg-100);">
                    <span class="line-clamp-1">{e.title}</span>
                    <span class="muted-2 mono" style="display: block; font-size: var(--t-label); margin-top: var(--s-1);">{e.source}</span>
                  </div>
                )}
                <div style="display: flex; gap: var(--s-1);">
                  {(e.tickers ?? []).slice(0, 3).map((t) => (
                    <a href={`/stocks/${t}/`} class="chip-mini ticker mono">{t}</a>
                  ))}
                </div>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  )}

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const bar = document.getElementById("filter-bar");
      if (!bar) return;
      bar.addEventListener("click", (ev) => {
        const t = ev.target;
        if (!(t instanceof HTMLElement) || !t.matches(".fbtn")) return;
        const want = t.getAttribute("data-kind") || "";
        bar.querySelectorAll(".fbtn").forEach((b) => b.removeAttribute("data-active"));
        t.setAttribute("data-active", "true");
        document.querySelectorAll("#cal .cal-row").forEach((row) => {
          const k = row.getAttribute("data-kind") || "";
          row.style.display = !want || k === want ? "" : "none";
        });
        document.querySelectorAll("#cal article").forEach((card) => {
          const visible = Array.from(card.querySelectorAll(".cal-row")).some((r) => r.style.display !== "none");
          card.style.display = visible ? "" : "none";
        });
      });
    });
  </script>
</Base>
