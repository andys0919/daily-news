---
import Base from "../layouts/Base.astro";
import guidance from "../data/guidance.json";

interface Item { title: string; link: string; source: string; published: string; direction: string; excerpt: string; tickers: string[]; event_type: string | null; }
interface FilingExcerpt { ticker: string; company_name: string; fiscal_year: number; fiscal_period: string; form_type: string; filed_at: string; excerpt: string; }

const all = (guidance.all ?? []) as Item[];
const up = (guidance.up ?? []) as Item[];
const down = (guidance.down ?? []) as Item[];
const mixed = all.filter((a) => a.direction === "mixed");
const neutral = all.filter((a) => a.direction === "neutral");
const byTicker = (guidance.by_ticker ?? {}) as Record<string, Item[]>;
const filings = (guidance.filing_excerpts ?? []) as FilingExcerpt[];
const generated = guidance.generated_at ?? "";
const tickers = Object.keys(byTicker).sort((a, b) => byTicker[b].length - byTicker[a].length).slice(0, 16);

function dirStyle(d: string): string {
  if (d === "up") return "color: var(--ok); border-color: rgba(61, 220, 151, 0.35); background: rgba(61, 220, 151, 0.08);";
  if (d === "down") return "color: var(--bad); border-color: rgba(255, 107, 129, 0.35); background: rgba(255, 107, 129, 0.08);";
  if (d === "mixed") return "color: var(--warn); border-color: rgba(255, 174, 92, 0.35); background: rgba(255, 174, 92, 0.08);";
  return "";
}
function ago(iso: string | undefined): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  const h = Math.floor((Date.now() - d.getTime()) / 3.6e6);
  if (h < 24) return `${h}h`;
  return `${Math.floor(h / 24)}d`;
}
function plainTitle(t: string): string { return (t || "").split(" - ")[0].trim(); }
---
<Base title="指引 Feed — 投資 dashboard" active="guidance">
  <header class="page-h">
    <div class="eyebrow">30 days · {all.length} 條事件</div>
    <h1>指引 <span class="accent">Feed</span></h1>
    <p>
      所有「上修」「下修」「目標價變動」「EPS beat / miss」的事件總表。從 55K 篇新聞用高精度短語比對標題抓出來，再依方向分類。可篩選方向、依 ticker 聚合查看。
    </p>
    <div class="meta">
      <div>▲ 上修 <strong>{up.length}</strong></div>
      <div>▼ 下修 <strong>{down.length}</strong></div>
      <div>⇄ 混合 <strong>{mixed.length}</strong></div>
      <div>─ 維持 <strong>{neutral.length}</strong></div>
    </div>
  </header>

  <aside class="howto">
    <div class="howto-icon">i</div>
    <div>
      <p class="howto-title">怎麼用這頁</p>
      <p class="howto-body">
        <strong>左側列表</strong>是時序事件流，預設全部依時間倒排。<strong>篩選按鈕</strong>可只看上修或只看下修。<strong>右側 Per-ticker</strong>聚合顯示哪些個股最常出現在指引事件中（按頻次排序）。<strong>SEC Filings</strong>是美股 10-Q 中由公司自己寫的 forward-looking statements 原文。
      </p>
    </div>
  </aside>

  <div class="filters" id="filter-bar">
    <button class="fbtn" data-dir="" data-active="true">全部 · {all.length}</button>
    <button class="fbtn" data-dir="up">▲ 上修 · {up.length}</button>
    <button class="fbtn" data-dir="down">▼ 下修 · {down.length}</button>
    <button class="fbtn" data-dir="mixed">⇄ 混合 · {mixed.length}</button>
    <button class="fbtn" data-dir="neutral">─ 維持 · {neutral.length}</button>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <section class="lg:col-span-2">
      <div class="timeline" id="feed">
        {all.map((g) => (
          <article class="tl-item" data-dir={g.direction}>
            <div class="tl-stamp">
              <div>{(g.published ?? "").slice(0, 10)}</div>
              <div class="muted-2">{ago(g.published)}</div>
            </div>
            <div class="tl-body">
              <div class="h">
                <span class="chip-mini" style={dirStyle(g.direction)}>{g.direction.toUpperCase()}</span>
                <a href={g.link} target="_blank" rel="noopener"><strong>{plainTitle(g.title)}</strong></a>
              </div>
              {g.excerpt && <p class="summary line-clamp-2">{g.excerpt}</p>}
              <div class="tags">
                <span class="chip-mini">{g.source}</span>
                {g.tickers.slice(0, 4).map((t) => (
                  <a href={`/stocks/${t}/`} class="chip-mini ticker mono">{t}</a>
                ))}
              </div>
            </div>
          </article>
        ))}
        {all.length === 0 && <p class="muted" style="padding: var(--s-6);">（本週無指引事件）</p>}
      </div>
    </section>

    <aside>
      <article class="glass bento" style="margin-bottom: var(--s-4);">
        <header class="bento-head">
          <h2 class="bento-title">出現次數最多的個股</h2>
          <span class="bento-link mono">{tickers.length}</span>
        </header>
        <div class="lb">
          {tickers.map((t, i) => (
            <a class="lb-row" href={`/stocks/${t}/`}>
              <span class="rank mono">#{(i + 1).toString().padStart(2, "0")}</span>
              <span class="name mono"><strong>{t}</strong></span>
              <span class="v">{byTicker[t].length} 條</span>
            </a>
          ))}
          {tickers.length === 0 && <p class="muted" style="font-size: var(--t-small); padding: var(--s-3);">（無聚合資料）</p>}
        </div>
      </article>

      <article class="glass bento">
        <header class="bento-head">
          <h2 class="bento-title">SEC Filing 摘錄</h2>
          <span class="bento-link mono">{filings.length}</span>
        </header>
        <div>
          {filings.length === 0 ? (
            <p class="muted" style="font-size: var(--t-small); padding: var(--s-3);">（需執行 stock_memo.py 觸發 SEC ingest）</p>
          ) : (
            filings.map((f) => (
              <div style="border-top: 1px solid var(--border-base); padding-top: var(--s-3); margin-top: var(--s-3);">
                <div style="display: flex; align-items: baseline; gap: var(--s-2); flex-wrap: wrap; margin-bottom: var(--s-1);">
                  <a href={`/stocks/${f.ticker}/`} class="mono" style="color: var(--accent-strong); font-weight: 500; font-size: var(--t-small);">{f.ticker}</a>
                  <span class="muted-2 mono" style="font-size: var(--t-caption);">{f.form_type} · {f.fiscal_year}{f.fiscal_period}</span>
                </div>
                <p class="line-clamp-4" style="font-size: var(--t-label); line-height: 1.6; color: var(--fg-300); margin: 0;">
                  {f.excerpt}
                </p>
              </div>
            ))
          )}
        </div>
      </article>
    </aside>
  </div>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const bar = document.getElementById("filter-bar");
      const items = Array.from(document.querySelectorAll("#feed .tl-item"));
      if (!bar) return;
      bar.addEventListener("click", (ev) => {
        const t = ev.target;
        if (!(t instanceof HTMLElement) || !t.matches(".fbtn")) return;
        const want = t.getAttribute("data-dir") || "";
        bar.querySelectorAll(".fbtn").forEach((b) => b.removeAttribute("data-active"));
        t.setAttribute("data-active", "true");
        items.forEach((el) => {
          const dir = el.getAttribute("data-dir") || "";
          el.style.display = !want || dir === want ? "" : "none";
        });
      });
    });
  </script>
</Base>
