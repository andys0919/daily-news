---
import Base from "../layouts/Base.astro";
import screens from "../data/screens.json";

interface MomentumRow { ticker: string; mentions_7d: number; mentions_prior_7d: number; delta: number; pct_change: number }
interface Theme { theme: string; count: number; examples: any[] }
interface NewsItem { title: string; link: string; source: string; published: string; tickers: string[] }

const momentum = (screens.momentum ?? []) as MomentumRow[];
const themes = (screens.themes ?? []) as Theme[];
const clusters: any = screens.event_clusters ?? {};
const earnings = (clusters.earnings ?? []) as NewsItem[];
const capex = (clusters.capex ?? []) as NewsItem[];
const policy = (clusters.policy ?? []) as NewsItem[];

function ago(iso: string | undefined): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  const h = Math.floor((Date.now() - d.getTime()) / 3.6e6);
  if (h < 1) return "<1h";
  if (h < 24) return `${h}h`;
  return `${Math.floor(h / 24)}d`;
}
---
<Base title="Screen — 投資 idea 篩選" active="screens">
  <section class="hero">
    <div>
      <span class="live"><span class="live-dot"></span>screens · {momentum.length + themes.length} ideas</span>
      <h1 class="mt-2">投資 <span class="accent">idea</span> screen</h1>
      <p class="hero-sub">基於 30 天新聞流量自動聚類：動能、主題、事件叢集。供研究起點，非投資建議。</p>
    </div>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">💫 Mention momentum · 7d vs prior 7d</h2>
        <span class="bento-link mono">{momentum.length}</span>
      </header>
      <div class="lb">
        {momentum.map((m, i) => (
          <a class="lb-row" href={`/stocks/${m.ticker}`}>
            <div style="display:flex; align-items:baseline; gap:10px;">
              <span class="rank mono">#{(i + 1).toString().padStart(2, "0")}</span>
              <span class="name mono"><strong>{m.ticker}</strong></span>
              <span class="muted-2 mono" style="font-size:10px;">prev {m.mentions_prior_7d}</span>
            </div>
            <span class="v">{m.mentions_7d}</span>
            <span class={`delta ${m.delta > 0 ? "up" : m.delta < 0 ? "down" : "flat"}`}>
              {m.delta >= 0 ? "+" : ""}{m.delta} · {m.pct_change > 0 ? "+" : ""}{m.pct_change}%
            </span>
          </a>
        ))}
        {momentum.length === 0 && <p class="muted text-sm">（無資料）</p>}
      </div>
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">🧬 主題熱度 · 30d</h2>
        <a href="/themes" class="bento-link">主題詳情 →</a>
      </header>
      <div class="theme-cloud" style="margin-bottom:14px;">
        {themes.slice(0, 12).map((t, i) => (
          <a href={`/themes#${encodeURIComponent(t.theme)}`} class={`theme-chip ${i < 3 ? "hot" : ""}`}>
            <span>{t.theme}</span>
            <span class="n">{t.count}</span>
          </a>
        ))}
      </div>
      {themes.slice(0, 4).map((t) => (
        <div style="margin-top:14px;">
          <div style="font-size:12px; color: var(--fg-200); margin-bottom:4px;">
            <strong>{t.theme}</strong>
            <span class="muted-2 mono" style="font-size:10px; margin-left:6px;">{t.count}</span>
          </div>
          {(t.examples ?? []).slice(0, 2).map((e: any) => (
            <a href={e.link} target="_blank" rel="noopener" class="muted" style="display:block; font-size:11.5px; line-height:1.4; padding:3px 0;">
              · <span class="line-clamp-1">{e.title}</span>
            </a>
          ))}
        </div>
      ))}
    </article>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">📊 Earnings 叢集</h2>
        <span class="bento-link mono">{earnings.length}</span>
      </header>
      <div class="signals">
        {earnings.slice(0, 12).map((e) => (
          <a class="signal" href={e.link} target="_blank" rel="noopener">
            <span class="signal-tag transcript">earn</span>
            <div class="signal-body">
              <div class="line-clamp-2">{e.title}</div>
              <div class="meta">{e.source} · {e.tickers?.slice(0, 3).join(", ")}</div>
            </div>
            <span class="signal-meta">{ago(e.published)}</span>
          </a>
        ))}
      </div>
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">🏗 Capex 叢集</h2>
        <span class="bento-link mono">{capex.length}</span>
      </header>
      <div class="signals">
        {capex.slice(0, 12).map((e) => (
          <a class="signal" href={e.link} target="_blank" rel="noopener">
            <span class="signal-tag holdings">capex</span>
            <div class="signal-body">
              <div class="line-clamp-2">{e.title}</div>
              <div class="meta">{e.source} · {e.tickers?.slice(0, 3).join(", ")}</div>
            </div>
            <span class="signal-meta">{ago(e.published)}</span>
          </a>
        ))}
      </div>
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">🏛 Policy 叢集</h2>
        <span class="bento-link mono">{policy.length}</span>
      </header>
      <div class="signals">
        {policy.slice(0, 12).map((e) => (
          <a class="signal" href={e.link} target="_blank" rel="noopener">
            <span class="signal-tag insider">policy</span>
            <div class="signal-body">
              <div class="line-clamp-2">{e.title}</div>
              <div class="meta">{e.source} · {e.tickers?.slice(0, 3).join(", ")}</div>
            </div>
            <span class="signal-meta">{ago(e.published)}</span>
          </a>
        ))}
      </div>
    </article>
  </section>
</Base>
