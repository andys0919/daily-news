---
import Base from "../layouts/Base.astro";
import news from "../data/news.json";

interface Article {
  title: string; link: string; source: string; category: string; published: string;
  summary?: string; tickers?: string[]; companies?: string[]; event_type?: string;
}

const articles = (news.articles ?? []) as Article[];
const categories = Array.from(new Set(articles.map((a) => a.category))).filter(Boolean) as string[];
---
<Base title="新聞 — 投資 dashboard" active="news">
  <header class="page-h">
    <div class="eyebrow">latest · {articles.length} 篇</div>
    <h1>新聞 <span class="accent">時間軸</span></h1>
    <p>
      所有來源最近 {articles.length} 篇文章，依時間倒排。可依分類篩選。<strong>注意</strong>：這頁是「全部新聞」原始流量，含部分噪音。如果只想看有投資意義的事件，請去
      <a href="/guidance/" style="color: var(--accent-strong); text-decoration: underline;">/guidance</a>。
    </p>
  </header>

  <aside class="howto">
    <div class="howto-icon">i</div>
    <div>
      <p class="howto-title">怎麼用這頁</p>
      <p class="howto-body">
        <strong>分類按鈕</strong>篩選新聞主題，<strong>ticker 籤</strong>點下去跳到該檔個股頁，<strong>event 籤</strong>（earnings / capex / policy）標記 daily-news pipeline 判定為事件性新聞。對快速翻閱當日新聞流量有用。
      </p>
    </div>
  </aside>

  <div class="filters" id="filter-bar">
    <button class="fbtn" data-cat="" data-active="true">全部 · {articles.length}</button>
    {categories.map((c) => (
      <button class="fbtn" data-cat={c}>{c}</button>
    ))}
  </div>

  <div class="timeline" id="timeline">
    {articles.map((a) => (
      <article class="tl-item" data-cat={a.category} data-evt={a.event_type ?? ""}>
        <div class="tl-stamp">
          <div>{(a.published ?? "").slice(0, 10)}</div>
          <div class="muted-2">{(a.published ?? "").slice(11, 16)}</div>
        </div>
        <div class="tl-body">
          <div class="h">
            <a href={a.link} target="_blank" rel="noopener"><strong>{a.title}</strong></a>
            <span class="muted-2 mono" style="font-size: var(--t-label);">· {a.source}</span>
          </div>
          {a.summary && <p class="summary line-clamp-2">{a.summary}</p>}
          <div class="tags">
            {a.category && <span class="chip-mini">{a.category}</span>}
            {a.event_type && a.event_type !== "news" && <span class={`chip-mini evt-${a.event_type}`}>{a.event_type}</span>}
            {(a.tickers ?? []).slice(0, 5).map((t) => (
              <a href={`/stocks/${t}/`} class="chip-mini ticker mono">{t}</a>
            ))}
          </div>
        </div>
      </article>
    ))}
  </div>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const bar = document.getElementById("filter-bar");
      const items = Array.from(document.querySelectorAll("#timeline .tl-item"));
      if (!bar) return;
      bar.addEventListener("click", (ev) => {
        const target = ev.target;
        if (!(target instanceof HTMLElement) || !target.matches(".fbtn")) return;
        const want = target.getAttribute("data-cat") || "";
        bar.querySelectorAll(".fbtn").forEach((b) => b.removeAttribute("data-active"));
        target.setAttribute("data-active", "true");
        items.forEach((el) => {
          const cat = el.getAttribute("data-cat") || "";
          el.style.display = !want || cat === want ? "" : "none";
        });
      });
    });
  </script>
</Base>
