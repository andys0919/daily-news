  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      // Tab switcher for the pulse feed
      const tabs = document.querySelectorAll("#feed-tabs .tab");
      const panels = document.querySelectorAll(".feed-panel");
      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.getAttribute("data-tab");
          tabs.forEach((t) => t.removeAttribute("data-active"));
          tab.setAttribute("data-active", "true");
          panels.forEach((p) => {
            p.style.display = p.getAttribute("data-panel") === target ? "" : "none";
          });
        });
      });

      // Section-index active highlight based on scroll position
      const navLinks = document.querySelectorAll("#sec-nav a");
      const sections = ["takeaway", "scorecard", "pulse", "filings", "gaps"]
        .map((id) => document.getElementById(id))
        .filter(Boolean);
      function updateActive() {
        let current = sections[0]?.id;
        const top = window.scrollY + 200;
        for (const s of sections) {
          if (s.offsetTop <= top) current = s.id;
        }
        navLinks.forEach((a) => {
          a.toggleAttribute("data-current", a.getAttribute("data-target") === current);
        });
      }
      window.addEventListener("scroll", updateActive, { passive: true });
      updateActive();
    });
  </script>
