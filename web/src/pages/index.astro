---
import Base from "../layouts/Base.astro";
import overview from "../data/overview.json";

interface Guidance { title: string; link: string; source: string; published: string; direction: string; excerpt: string; tickers: string[]; }
interface Analyst { title: string; link: string; source: string; published: string; tickers: string[]; direction: string | null; summary: string; }
interface RevenueRow {
  ticker: string; market: string; company_name: string | null;
  q_year: number | null; q_period: string | null;
  q_revenue: number | null; q_eps: number | null; q_rev_yoy: number | null;
  m_year: number | null; m_period: string | null; m_revenue: number | null;
}
interface InternalItem { title: string; link: string; source: string; published: string; tickers: string[]; event_type: string | null; }
interface FilingExcerpt { ticker: string; company_name: string; fiscal_year: number; fiscal_period: string; form_type: string; filed_at: string; excerpt: string; }
interface Fundamental {
  ticker: string; market: string; company_name: string | null;
  latest: any;
  health: { tier: string; label: string; summary: string; icon: string };
  guidance: { up: number; down: number; net: number };
}
interface Take { kind: string; headline: string; detail: string; }

const stats: any = overview.stats ?? {};
const takeaways = (overview.takeaways ?? []) as Take[];
const fundamentals = (overview.fundamentals ?? []) as Fundamental[];
const guidanceUp = (overview.guidance_up ?? []) as Guidance[];
const guidanceDown = (overview.guidance_down ?? []) as Guidance[];
const guidanceRecent = (overview.guidance_recent ?? []) as Guidance[];
const analyst = (overview.analyst_views ?? []) as Analyst[];
const revenue = (overview.revenue_pulse ?? []) as RevenueRow[];
const internal = (overview.internal_feed ?? []) as InternalItem[];
const filings = (overview.filing_excerpts ?? []) as FilingExcerpt[];
const generated = overview.generated_at ?? "";

function fmtMoney(n: number | null | undefined, scale = 1e9, digits = 2, suffix = "B"): string {
  if (n == null || isNaN(Number(n))) return "—";
  return `${(Number(n) / scale).toFixed(digits)}${suffix}`;
}
function fmtPct(n: number | null | undefined): string {
  if (n == null || isNaN(Number(n))) return "—";
  return `${n >= 0 ? "+" : ""}${Number(n).toFixed(1)}%`;
}
function fmtNum(n: number | null | undefined, digits = 2): string {
  if (n == null || isNaN(Number(n))) return "—";
  return Number(n).toFixed(digits);
}
function ago(iso: string | undefined): string {
  if (!iso) return "—";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  const h = Math.floor((Date.now() - d.getTime()) / 3.6e6);
  if (h < 1) return "<1h";
  if (h < 24) return `${h}h`;
  return `${Math.floor(h / 24)}d`;
}
function plainTitle(t: string): string { return (t || "").split(" - ")[0].trim(); }
function deltaCls(n: number | null | undefined): string {
  if (n == null) return "delta-flat";
  if (n > 0) return "delta-up";
  if (n < 0) return "delta-down";
  return "delta-flat";
}

const tierOrder: Record<string, number> = { strong: 0, steady: 1, watch: 2, warn: 3, unknown: 4 };

const revByTicker: Record<string, RevenueRow> = {};
for (const r of revenue) revByTicker[r.ticker] = r;

const analystCount: Record<string, { up: number; down: number; total: number }> = {};
for (const a of analyst) {
  for (const t of a.tickers || []) {
    if (!analystCount[t]) analystCount[t] = { up: 0, down: 0, total: 0 };
    analystCount[t].total++;
    if (a.direction === "up") analystCount[t].up++;
    if (a.direction === "down") analystCount[t].down++;
  }
}

const latestEventByTicker: Record<string, { title: string; direction: string; published: string; link: string }> = {};
for (const g of guidanceRecent) {
  for (const t of g.tickers || []) {
    const cur = latestEventByTicker[t];
    if (!cur || (g.published || "") > cur.published) {
      latestEventByTicker[t] = { title: g.title, direction: g.direction, published: g.published, link: g.link };
    }
  }
}

const sortedFundamentals = [...fundamentals].sort((a, b) =>
  (tierOrder[a.health?.tier ?? "unknown"] ?? 5) - (tierOrder[b.health?.tier ?? "unknown"] ?? 5)
);

const analystByTicker: Record<string, Analyst[]> = {};
for (const a of analyst) {
  for (const t of a.tickers || []) {
    if (!analystByTicker[t]) analystByTicker[t] = [];
    analystByTicker[t].push(a);
  }
}
const analystTickers = Object.keys(analystByTicker).sort((a, b) => analystByTicker[b].length - analystByTicker[a].length).slice(0, 8);

// Tier distribution for hero meta
const tierDist: Record<string, number> = { strong: 0, steady: 0, watch: 0, warn: 0, unknown: 0 };
for (const f of sortedFundamentals) {
  tierDist[f.health?.tier ?? "unknown"]++;
}
---
<Base title="投資 dashboard · 一頁總覽" active="home">
  <!-- HERO ─────────────────────────────────────────────────── -->
  <header class="page-h">
    <div class="eyebrow">{generated.slice(0, 10)} · {ago(generated)} ago · daily refresh</div>
    <h1>投資 <span class="accent">一頁</span> 看完</h1>
    <p>
      把今天該關注的「指引變動、法人看法、營收動能、公司內部資料、watchlist 健康度」濃縮在一頁。
      <strong>主視角是個股 Scorecard</strong> — 一行一檔，橫掃看完。下面是訊號流、公司原文、資料缺口說明。
    </p>
    <div class="meta">
      <div>24h <strong>{stats.articles_24h ?? 0}</strong></div>
      <div>▲ 上修 <strong>{stats.guidance_up_30d ?? 0}</strong></div>
      <div>▼ 下修 <strong>{stats.guidance_down_30d ?? 0}</strong></div>
      <div>🟢 強 <strong>{tierDist.strong}</strong></div>
      <div>🔵 穩 <strong>{tierDist.steady}</strong></div>
      <div>🟡 觀望 <strong>{tierDist.watch}</strong></div>
      <div>個股 <strong>{stats.tickers_tracked ?? 0}</strong></div>
    </div>
  </header>

  <!-- STICKY SECTION INDEX -->
  <nav class="sec-index" id="sec-nav">
    <a href="#takeaway" data-target="takeaway">今日重點</a>
    <a href="#scorecard" data-target="scorecard">個股 Scorecard</a>
    <a href="#pulse" data-target="pulse">訊號流</a>
    <a href="#filings" data-target="filings">公司原文</a>
    <a href="#gaps" data-target="gaps">資料缺口</a>
  </nav>

  <!-- MASTER GUIDE (single collapsible card) -->
  <details class="guide">
    <summary>
      <span class="icon">i</span>
      <span class="label">本頁如何使用</span>
      <span class="meta">展開閱讀</span>
    </summary>
    <div class="guide-body">
      <div>
        <h4>1. 健康度怎麼判定</h4>
        <p>從財報數字計算分數：營收 YoY、營益率、FCF margin、成長加速度。對照：</p>
        <ul>
          <li><strong>🟢 強勢</strong>：營收年增 ≥20% 且營益率 ≥30%（業界頂尖）</li>
          <li><strong>🔵 穩健</strong>：營收成長健康 + 營益率 ≥15%</li>
          <li><strong>🟡 觀望</strong>：成長平平或營益率偏低</li>
          <li><strong>🔴 警示</strong>：營收衰退或營益率 &lt;5%</li>
          <li><strong>⚫ 資料不足</strong>：尚未建檔，需執行 stock_memo.py</li>
        </ul>
      </div>
      <div>
        <h4>2. 上修 / 下修怎麼算</h4>
        <p>從新聞<strong>標題</strong>抓 high-precision 短語：</p>
        <ul>
          <li><strong>▲ 上修</strong>：raises guidance / lifts target / beats estimates / 上修目標價 / 上看 …</li>
          <li><strong>▼ 下修</strong>：cuts guidance / misses EPS / 下修財測 / slashes …</li>
        </ul>
        <p>只看標題、避免被內文政治 / 噪音帶風向。</p>
      </div>
      <div>
        <h4>3. 訊號流三個 tab</h4>
        <ul>
          <li><strong>指引</strong>：明確的財測 / 目標價變動。最直接的訊號。</li>
          <li><strong>法人</strong>：分析師報告、外資、投信動向。Lagging signal，反映共識。</li>
          <li><strong>公司內部</strong>：法說、IR、SEC filing、capex 公告。公司原文，最權威。</li>
        </ul>
      </div>
      <div>
        <h4>4. 操作小技巧</h4>
        <ul>
          <li>按 <span class="kbd">/</span> 開啟搜尋框，可搜 ticker 或公司名</li>
          <li>Scorecard 每行可點，進該檔個股深度頁</li>
          <li>ticker chip（藍色小方塊）哪裡都可點</li>
          <li>本工具僅彙整公開資訊，<strong>非投資建議</strong></li>
        </ul>
      </div>
    </div>
  </details>

  <!-- TAKEAWAY ──────────────────────────────────────────────── -->
  <section id="takeaway">
    <div class="section-h2">
      <h2>今日重點</h2>
      <span class="h-sub">一句話總結今天市場的方向</span>
    </div>
    <div class="take-cards" style="margin-bottom: var(--s-12);">
      {takeaways.map((t) => (
        <div class={`take ${t.kind}`}>
          <div class="take-tag">{t.kind === "positive" ? "▲ 偏正面" : t.kind === "negative" ? "▼ 偏負面" : "─ 中性"}</div>
          <div class="take-headline">{t.headline}</div>
          <div class="take-detail">{t.detail}</div>
        </div>
      ))}
      {takeaways.length === 0 && (
        <div class="take neutral" style="grid-column: 1 / -1;">
          <div class="take-tag">─ pipeline 待跑</div>
          <div class="take-headline">尚未產生今日 takeaway</div>
        </div>
      )}
    </div>
  </section>

  <!-- SCORECARD — main centerpiece ─────────────────────────── -->
  <section id="scorecard">
    <div class="section-h2">
      <h2>個股 Scorecard</h2>
      <span class="h-sub">{sortedFundamentals.length} 檔 · 健康度・營收・法人・最近事件</span>
      <a href="#pulse" class="h-link">完整訊號流 ↓</a>
    </div>

    <!-- Desktop table (sticky header) -->
    <div class="scorecard-wrap">
      <table class="scorecard">
        <thead>
          <tr>
            <th class="left" style="width: 26%;">個股</th>
            <th>健康度</th>
            <th>季營收</th>
            <th>EPS</th>
            <th>Rev YoY</th>
            <th>月營收</th>
            <th>分析師</th>
            <th class="left">最近事件</th>
          </tr>
        </thead>
        <tbody>
          {sortedFundamentals.map((f) => {
            const h = f.health ?? { tier: "unknown", label: "—", summary: "", icon: "⚫" };
            const r = revByTicker[f.ticker];
            const a = analystCount[f.ticker];
            const evt = latestEventByTicker[f.ticker];
            const g = f.guidance ?? { up: 0, down: 0, net: 0 };
            return (
              <tr onclick={`window.location='/stocks/${f.ticker}/'`}>
                <td class="left">
                  <div class="ticker-cell">
                    <span class="icon">{h.icon}</span>
                    <div>
                      <div class="t">{f.ticker}</div>
                      <div class="name">{f.company_name?.slice(0, 22) ?? ""}</div>
                    </div>
                  </div>
                </td>
                <td><span class={`tier ${h.tier}`}>{h.label}</span></td>
                <td>{r?.q_revenue ? fmtMoney(r.q_revenue, 1e9, 1) : "—"}</td>
                <td>{r?.q_eps != null ? fmtNum(r.q_eps, 2) : "—"}</td>
                <td class={deltaCls(r?.q_rev_yoy)}>{fmtPct(r?.q_rev_yoy)}</td>
                <td>{r?.m_revenue ? fmtMoney(r.m_revenue, 1e9, 2) : "—"}</td>
                <td>
                  {(a?.up ?? 0) > 0 && <span class="delta-up">↑{a!.up}</span>}
                  {(a?.up ?? 0) > 0 && (a?.down ?? 0) > 0 && " · "}
                  {(a?.down ?? 0) > 0 && <span class="delta-down">↓{a!.down}</span>}
                  {!a && (g.up + g.down > 0) && (
                    <>
                      {g.up > 0 && <span class="delta-up">↑{g.up}</span>}
                      {g.up > 0 && g.down > 0 && " · "}
                      {g.down > 0 && <span class="delta-down">↓{g.down}</span>}
                    </>
                  )}
                  {!a && g.up + g.down === 0 && <span class="delta-flat">—</span>}
                </td>
                <td class={`latest-event ${evt?.direction === "up" ? "up" : evt?.direction === "down" ? "down" : ""}`}>
                  {evt ? (
                    <>
                      {evt.direction === "up" && "▲ "}
                      {evt.direction === "down" && "▼ "}
                      {plainTitle(evt.title)}
                    </>
                  ) : <span class="muted-2">—</span>}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <!-- Mobile cards (replaces table on small screens) -->
    <div class="scorecard-mobile" style="margin-bottom: var(--s-12);">
      {sortedFundamentals.map((f) => {
        const h = f.health ?? { tier: "unknown", label: "—", summary: "", icon: "⚫" };
        const r = revByTicker[f.ticker];
        const a = analystCount[f.ticker];
        return (
          <a href={`/stocks/${f.ticker}/`} class="score-card-m">
            <div class="icon">{h.icon}</div>
            <div class="body">
              <div class="head">
                <span class="t">{f.ticker}</span>
                <span class={`tier ${h.tier}`}>{h.label}</span>
                {f.company_name && <span class="name">{f.company_name.slice(0, 16)}</span>}
              </div>
              <div class="stats">
                Q rev {r?.q_revenue ? fmtMoney(r.q_revenue, 1e9, 1) : "—"}
                {r?.q_rev_yoy != null && (
                  <> · <span class={deltaCls(r.q_rev_yoy)}>{fmtPct(r.q_rev_yoy)}</span></>
                )}
                {a && (
                  <>
                    {" · "}
                    {a.up > 0 && <span class="delta-up">↑{a.up}</span>}
                    {a.up > 0 && a.down > 0 && " "}
                    {a.down > 0 && <span class="delta-down">↓{a.down}</span>}
                  </>
                )}
              </div>
            </div>
            <div class="right">
              {r?.q_eps != null ? fmtNum(r.q_eps, 2) : "—"}
              <div style="color: var(--fg-500); font-size: 9px;">EPS</div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- UNIFIED PULSE (tabs) ─────────────────────────────────── -->
  <section id="pulse">
    <div class="section-h2">
      <h2>訊號流</h2>
      <span class="h-sub">指引 / 法人 / 公司內部 — 切換 tab 看不同來源</span>
    </div>

    <div class="tabs" id="feed-tabs">
      <button class="tab" data-tab="guidance" data-active="true">指引<span class="count">{guidanceUp.length + guidanceDown.length}</span></button>
      <button class="tab" data-tab="analyst">法人<span class="count">{analyst.length}</span></button>
      <button class="tab" data-tab="internal">公司內部<span class="count">{internal.length}</span></button>
    </div>

    <!-- Tab: Guidance -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 feed-panel" data-panel="guidance" style="margin-bottom: var(--s-12);">
      <div class="pulse">
        <div class="pulse-head">
          <span class="ttl"><span class="delta-up">▲</span> 上修 / Beat</span>
          <span class="count">{guidanceUp.length}</span>
        </div>
        {guidanceUp.slice(0, 12).map((g) => (
          <a class="pulse-row" href={g.link} target="_blank" rel="noopener">
            <span class="arrow up">▲</span>
            <div class="body">
              {g.tickers.length > 0 && <span class="ticker">{g.tickers[0]}</span>}
              {plainTitle(g.title)}
              <span class="meta">{g.source}</span>
            </div>
            <span class="time">{ago(g.published)}</span>
          </a>
        ))}
        {guidanceUp.length === 0 && <div class="pulse-row" style="grid-template-columns: 1fr; color: var(--fg-400);">（本週暫無上修事件）</div>}
      </div>

      <div class="pulse">
        <div class="pulse-head">
          <span class="ttl"><span class="delta-down">▼</span> 下修 / Miss</span>
          <span class="count">{guidanceDown.length}</span>
        </div>
        {guidanceDown.slice(0, 12).map((g) => (
          <a class="pulse-row" href={g.link} target="_blank" rel="noopener">
            <span class="arrow down">▼</span>
            <div class="body">
              {g.tickers.length > 0 && <span class="ticker">{g.tickers[0]}</span>}
              {plainTitle(g.title)}
              <span class="meta">{g.source}</span>
            </div>
            <span class="time">{ago(g.published)}</span>
          </a>
        ))}
        {guidanceDown.length === 0 && <div class="pulse-row" style="grid-template-columns: 1fr; color: var(--fg-400);">（本週暫無下修事件）</div>}
      </div>
    </div>

    <!-- Tab: Analyst -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 feed-panel" data-panel="analyst" style="margin-bottom: var(--s-12); display: none;">
      <div class="pulse lg:col-span-2">
        <div class="pulse-head">
          <span class="ttl">分析師 / 法人 / 評等變動</span>
          <span class="count">{analyst.length}</span>
        </div>
        {analyst.slice(0, 16).map((a) => (
          <a class="pulse-row" href={a.link} target="_blank" rel="noopener">
            <span class={`arrow ${a.direction === "up" ? "up" : a.direction === "down" ? "down" : "flat"}`}>
              {a.direction === "up" ? "▲" : a.direction === "down" ? "▼" : "·"}
            </span>
            <div class="body">
              {a.tickers.length > 0 && <span class="ticker">{a.tickers[0]}</span>}
              {plainTitle(a.title)}
              <span class="meta">{a.source}</span>
            </div>
            <span class="time">{ago(a.published)}</span>
          </a>
        ))}
        {analyst.length === 0 && <div class="pulse-row" style="grid-template-columns: 1fr; color: var(--fg-400);">（暫無）</div>}
      </div>

      <div class="pulse">
        <div class="pulse-head">
          <span class="ttl">出現次數最多</span>
          <span class="count">{analystTickers.length}</span>
        </div>
        {analystTickers.map((t, i) => (
          <a class="pulse-row" href={`/stocks/${t}/`}>
            <span class="arrow flat" style="font-family: 'JetBrains Mono', monospace; font-size: 10px;">#{(i + 1).toString().padStart(2, "0")}</span>
            <div class="body">
              <span class="ticker">{t}</span>
            </div>
            <span class="time">{analystByTicker[t].length} 條</span>
          </a>
        ))}
        {analystTickers.length === 0 && <div class="pulse-row" style="grid-template-columns: 1fr; color: var(--fg-400);">（無聚合資料）</div>}
      </div>
    </div>

    <!-- Tab: Internal -->
    <div class="grid grid-cols-1 gap-4 feed-panel" data-panel="internal" style="margin-bottom: var(--s-12); display: none;">
      <div class="pulse">
        <div class="pulse-head">
          <span class="ttl">法說 / IR / Capex 公告 / SEC Filing</span>
          <span class="count">{internal.length}</span>
        </div>
        {internal.slice(0, 18).map((n) => (
          <a class="pulse-row" href={n.link} target="_blank" rel="noopener">
            <span class="arrow flat">·</span>
            <div class="body">
              {n.tickers.length > 0 && <span class="ticker">{n.tickers[0]}</span>}
              {plainTitle(n.title)}
              <span class="meta">{n.source}{n.event_type && n.event_type !== "news" ? ` · ${n.event_type}` : ""}</span>
            </div>
            <span class="time">{ago(n.published)}</span>
          </a>
        ))}
        {internal.length === 0 && <div class="pulse-row" style="grid-template-columns: 1fr; color: var(--fg-400);">（暫無）</div>}
      </div>
    </div>
  </section>

  <!-- FILING EXCERPTS ──────────────────────────────────────── -->
  <section id="filings">
    <div class="section-h2">
      <h2>公司原文 · SEC 10-Q Forward-Looking</h2>
      <span class="h-sub">公司自己寫的未來經營展望，最權威</span>
    </div>
    {filings.length === 0 ? (
      <div class="filing-card">
        <p class="muted" style="font-size: var(--t-small);">（暫無 — 需執行 stock_memo.py 觸發 SEC ingest）</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4" style="margin-bottom: var(--s-12);">
        {filings.slice(0, 6).map((f) => (
          <article class="filing-card">
            <div class="filing-card-head">
              <a href={`/stocks/${f.ticker}/`} class="t">{f.ticker}</a>
              <span class="meta">{f.form_type} · {f.fiscal_year}{f.fiscal_period}</span>
              {f.company_name && <span class="name">{f.company_name}</span>}
            </div>
            <p class="excerpt line-clamp-4">{f.excerpt}</p>
          </article>
        ))}
      </div>
    )}
  </section>

  <!-- DATA GAPS ────────────────────────────────────────────── -->
  <section id="gaps">
    <div class="section-h2">
      <h2>資料缺口</h2>
      <span class="h-sub">誠實標示哪些資料還沒進來</span>
    </div>
    <article class="filing-card">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" style="font-size: var(--t-small); color: var(--fg-300); line-height: 1.7;">
        <div>
          <p style="color: var(--fg-100); font-weight: 500; margin-bottom: var(--s-2);">✓ 已有資料</p>
          <ul style="list-style: disc; padding-left: var(--s-5);">
            <li>{(stats.articles_total ?? 0).toLocaleString()} 篇新聞（ticker / event_type 標記）</li>
