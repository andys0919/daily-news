---
import Base from "../layouts/Base.astro";
import overview from "../data/overview.json";
import screens from "../data/screens.json";
import newsData from "../data/news.json";
import tickerIndex from "../data/tickers.json";

interface Article {
  title: string;
  link: string | null;
  source: string;
  published: string;
  tickers: string[];
  event_type: string | null;
  category?: string;
}
interface FilingExcerpt {
  ticker: string;
  company_name: string;
  fiscal_year: number;
  fiscal_period: string;
  form_type: string;
  excerpt: string;
}
interface MomentumRow {
  ticker: string;
  mentions_7d: number;
  mentions_prior_7d: number;
  delta: number;
  pct_change: number;
}
interface TickerEntry {
  ticker: string;
  name: string;
  market: string;
  articles: number;
  reports: number;
  label: string;
}
interface ActionLink {
  title: string;
  source: string | null;
  published: string | null;
  link: string | null;
}
interface ResearchQueueItem {
  ticker: string;
  display_name: string;
  score: number;
  thesis: string;
  why_now: string;
  next_step: string;
  checks: string[];
  evidence: {
    calls?: number | null;
    estimates?: number | null;
    news?: number | null;
    momentum_delta?: number | null;
    health?: string | null;
  };
  links: ActionLink[];
}
interface CallEvent {
  ticker: string;
  display_name: string;
  event_date: string | null;
  published: string | null;
  title: string;
  source: string | null;
  link: string | null;
  kind: string;
}
interface MarketCalendarEvent {
  kind: "macro" | "call" | "tw_event" | "us_event";
  label: string;
  date: string | null;
  time: string | null;
  ticker: string | null;
  display_name: string | null;
  title: string;
  source: string | null;
  link: string | null;
  importance: number;
}
interface AnalystEstimate {
  ticker: string;
  display_name: string;
  published: string | null;
  title: string;
  source: string | null;
  link: string | null;
  signal: string;
  direction: string | null;
}
interface NewsIndexItem {
  ticker: string;
  display_name: string;
  count: number;
  headlines: Array<{
    title: string;
    source: string | null;
    published: string | null;
    link: string | null;
    kind: string;
  }>;
}

const generated = overview.generated_at ?? "";
const articles = ((newsData as any).articles ?? []) as Article[];
const filings = (overview.filing_excerpts ?? []) as FilingExcerpt[];
const internalFeed = (overview.internal_feed ?? []) as Article[];
const momentumRows = ((screens as any).momentum ?? []) as MomentumRow[];
const stockSearchItems = ((tickerIndex as any).tickers ?? []) as TickerEntry[];
const actionBoard = ((overview as any).action_board ?? {}) as {
  research_queue?: ResearchQueueItem[];
  call_events?: CallEvent[];
  market_calendar?: MarketCalendarEvent[];
  analyst_estimates?: AnalystEstimate[];
  news_index?: NewsIndexItem[];
};

const researchQueue = actionBoard.research_queue ?? [];
const callEvents = actionBoard.call_events ?? [];
const marketCalendar = actionBoard.market_calendar ?? [];
const analystEstimates = actionBoard.analyst_estimates ?? [];
const newsIndex = actionBoard.news_index ?? [];
const callCalendar = buildMarketCalendar(marketCalendar, callEvents);
const marketCalendarSignalCount = marketCalendar.length;

const momentumByTicker: Record<string, MomentumRow> = {};
for (const row of momentumRows) momentumByTicker[row.ticker] = row;

function isStockSurfaceArticle(item: Article): boolean {
  if (!(item.tickers ?? []).length) return false;
  return !/github trending|arxiv|reddit r\/|hackernews|hugging face|sec form [345]|lobsters|servethehome/i.test(item.source || "");
}

const stockNews = articles.filter(isStockSurfaceArticle);
const internalStockFeed = internalFeed.filter(isStockSurfaceArticle);
const topSearchItems = stockSearchItems.slice(0, 12);
const hotTickers = topSearchItems
  .map((item) => ({ ...item, momentum: momentumByTicker[item.ticker] ?? null }))
  .sort((a, b) => (b.momentum?.delta ?? 0) - (a.momentum?.delta ?? 0) || b.articles - a.articles)
  .slice(0, 8);

function ago(iso: string | null | undefined): string {
  if (!iso) return "無時間";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  const h = Math.floor((Date.now() - d.getTime()) / 3.6e6);
  if (h < 1) return "<1h";
  if (h < 24) return `${h}h`;
  return `${Math.floor(h / 24)}d`;
}

function plainTitle(title: string): string {
  return (title || "").split(" - ")[0].replace(/\s+/g, " ").trim();
}

function marketLabel(market: string): string {
  return market === "tw" ? "TW" : "US";
}

function tickerHref(ticker: string | undefined): string {
  return ticker ? `/stocks/${ticker}/` : "#";
}

function itemHref(item: { link?: string | null; ticker?: string | null }): string {
  return item.link || tickerHref(item.ticker || undefined);
}

function dateLabel(iso: string | null | undefined): string {
  if (!iso) return "待確認";
  return iso.slice(0, 10);
}

function tickerName(item: { ticker: string; display_name?: string | null }): string {
  const name = (item.display_name || "").trim();
  return name && name !== item.ticker ? name : "";
}

function calendarTickerName(item: { ticker?: string | null; display_name?: string | null }): string {
  const ticker = item.ticker || "";
  const name = (item.display_name || "").trim();
  return name && name !== ticker ? name : "";
}

function formatMonthLabel(date: Date): string {
  return `${date.getFullYear()} 年 ${String(date.getMonth() + 1).padStart(2, "0")} 月`;
}

function isoDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}-${m}-${d}`;
}

function calendarEventKindClass(item: MarketCalendarEvent): string {
  return item.kind.replace("_", "-");
}

function calendarEventTitle(item: MarketCalendarEvent): string {
  if (item.ticker) return `${item.ticker}${calendarTickerName(item) ? ` ${calendarTickerName(item)}` : ""}`;
  return plainTitle(item.title);
}

function calendarEventMeta(item: MarketCalendarEvent): string {
  const parts: string[] = [];
  if (item.time) parts.push(item.time);
  if (item.source) parts.push(item.source);
  return parts.join(" · ");
}

const calendarKindPriority: Record<MarketCalendarEvent["kind"], number> = {
  call: 0,
  macro: 1,
  tw_event: 2,
  us_event: 3,
};

function calendarSignalsForDay(events: MarketCalendarEvent[]): MarketCalendarEvent[] {
  const sorted = [...events].sort(
    (a, b) => b.importance - a.importance || calendarKindPriority[a.kind] - calendarKindPriority[b.kind]
  );
  const picked: MarketCalendarEvent[] = [];
  for (const kind of ["call", "macro", "tw_event", "us_event"] as const) {
    const match = sorted.find((event) => event.kind === kind);
    if (match && !picked.includes(match)) picked.push(match);
  }
  for (const event of sorted) {
    if (picked.length >= 4) break;
    if (!picked.includes(event)) picked.push(event);
  }
  return picked;
}

function callToCalendarEvent(item: CallEvent): MarketCalendarEvent {
  return {
    kind: "call",
    label: "法說",
    date: item.event_date,
    time: null,
    ticker: item.ticker,
    display_name: item.display_name,
    title: item.title,
    source: item.source,
    link: item.link,
    importance: 80,
  };
}

function buildMarketCalendar(events: MarketCalendarEvent[], fallbackCalls: CallEvent[]) {
  const source = events.length ? events : fallbackCalls.map(callToCalendarEvent);
  const dated = source
    .filter((item) => item.date && !Number.isNaN(new Date(`${item.date}T00:00:00`).getTime()))
    .sort((a, b) =>
      String(a.date).localeCompare(String(b.date)) ||
      String(a.time || "00:00").localeCompare(String(b.time || "00:00")) ||
      b.importance - a.importance
    );
  if (!dated.length) return null;

  const anchor = new Date(`${dated[0].date}T00:00:00`);
  const first = new Date(anchor.getFullYear(), anchor.getMonth(), 1);
  const start = new Date(first);
  start.setDate(first.getDate() - first.getDay());

  const byDate = new Map<string, MarketCalendarEvent[]>();
  for (const event of dated) {
    const key = event.date || "";
    byDate.set(key, [...(byDate.get(key) ?? []), event]);
  }

  const days = Array.from({ length: 42 }, (_, index) => {
    const date = new Date(start);
    date.setDate(start.getDate() + index);
    const key = isoDate(date);
    return {
      date: key,
      day: date.getDate(),
      inMonth: date.getMonth() === anchor.getMonth(),
      events: byDate.get(key) ?? [],
    };
  });

  return {
    label: formatMonthLabel(anchor),
    weekdays: ["日", "一", "二", "三", "四", "五", "六"],
    days,
  };
}

const sourceTiles = [
  { label: "研究指引", value: researchQueue.length, sub: "下一步 / 查核重點", tone: "news", href: "research-guide" },
  { label: "市場日曆", value: marketCalendarSignalCount || callEvents.length, sub: "重要總經 / 法說 / 台美股事件", tone: "calls", href: "calls" },
  { label: "法人預估", value: analystEstimates.length, sub: "目標價 / 上修 / 下修", tone: "analyst", href: "estimates" },
  { label: "新聞索引", value: newsIndex.length, sub: "ticker 對應新聞", tone: "financials", href: "news-index" },
];
---
<Base title="個股快搜 · Daily-News" active="home">
  <section class="search-hero">
    <div class="search-hero-copy">
      <span class="portal-kicker">即時個股資訊入口 · {generated.slice(0, 10)} · {ago(generated)} ago</span>
      <h1>個股快搜</h1>
      <p>
        這裡不再把所有網站丟成一條流水帳。idea-generation 先把個股資料整理成研究指引、法說時間、法人預估與新聞索引，讓你一眼知道哪一檔要查、下一步要看什麼、證據在哪裡。
      </p>

      <div class="stock-command">
        <span class="command-icon">⌕</span>
        <input
          id="stock-command-input"
          type="text"
          placeholder="快速搜尋 2330、NVDA、台積電、NVIDIA..."
          autocomplete="off"
          spellcheck="false"
        />
        <kbd class="kbd">Enter</kbd>
        <div id="stock-command-results" class="ticker-result-list" hidden></div>
      </div>

      <div class="quick-strip" aria-label="popular ticker shortcuts">
        <span>熱門快搜</span>
        {hotTickers.map((item) => (
          <a href={`/stocks/${item.ticker}/`}>{item.ticker}</a>
        ))}
      </div>
    </div>

    <div class="coverage-grid">
      {sourceTiles.map((tile) => (
        <a class={`coverage-card ${tile.tone}`} href={`#${tile.href}`}>
          <span>{tile.label}</span>
          <strong>{tile.value}</strong>
          <em>{tile.sub}</em>
        </a>
      ))}
    </div>
  </section>

  <nav class="sec-index" id="sec-nav">
    <a href="#research-guide" data-target="research-guide">研究指引</a>
    <a href="#calls" data-target="calls">市場日曆</a>
    <a href="#estimates" data-target="estimates">法人預估</a>
    <a href="#news-index" data-target="news-index">新聞索引</a>
  </nav>

  <section class="news-calendar-workbench" aria-label="新聞與市場日曆工作台">
    <div class="news-column">
      <section id="research-guide" class="workbench-panel research-panel">
    <div class="section-title compact">
      <span>01</span>
      <div>
        <h2>研究指引</h2>
        <p>先看下一步，再決定要不要打開個股頁深挖；避免只滑過一堆新聞標題。</p>
      </div>
    </div>

    {researchQueue.length > 0 ? (
      <div class="action-grid">
        {researchQueue.slice(0, 3).map((item) => (
          <article class="action-card">
            <header>
              <a class="ticker-name" href={tickerHref(item.ticker)}>
                <strong>{item.ticker}</strong>
                {tickerName(item) && <span>{tickerName(item)}</span>}
              </a>
            </header>
            <h3>{item.thesis}</h3>
            <p>{item.why_now}</p>
            <p class="next-step">{item.next_step}</p>
            <div class="action-evidence">
              <span>{item.evidence.calls ?? 0} 法說</span>
              <span>{item.evidence.estimates ?? 0} 法人</span>
              <span>{item.evidence.news ?? 0} 新聞</span>
              {item.evidence.momentum_delta != null && <span>動能 +{item.evidence.momentum_delta}</span>}
            </div>
            <div class="check-list">
              {item.checks.map((check) => <span>{check}</span>)}
            </div>
            <div class="evidence-link-list">
              {item.links.slice(0, 3).map((link) => (
                <a href={link.link || tickerHref(item.ticker)} target={link.link ? "_blank" : undefined} rel={link.link ? "noopener" : undefined}>
                  <strong>{plainTitle(link.title)}</strong>
                  <em>{link.source} · {ago(link.published)}</em>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p class="empty-state">目前沒有足夠的個股證據形成研究指引。</p>
    )}
  </section>

      <section id="estimates" class="workbench-panel estimates-panel">
    <div class="section-title compact">
      <span>03</span>
      <div>
        <h2>法人預估</h2>
        <p>只收斂到法人、分析師、目標價、預估或財測變動，避免混進一般新聞雜訊。</p>
      </div>
    </div>

    {analystEstimates.length > 0 ? (
      <div class="estimate-grid">
        {analystEstimates.slice(0, 12).map((item) => (
          <a class={`estimate-card ${item.direction ?? "neutral"}`} href={itemHref(item)} target={item.link ? "_blank" : undefined} rel={item.link ? "noopener" : undefined}>
            <header>
              <span class="ticker-name">
                <strong>{item.ticker}</strong>
                {tickerName(item) && <span>{tickerName(item)}</span>}
              </span>
              <span>{item.signal}</span>
            </header>
            <p>{plainTitle(item.title)}</p>
            <em>{item.source} · {ago(item.published)}</em>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty-state">目前沒有法人預估或目標價更新。</p>
    )}
  </section>

      <section id="news-index" class="workbench-panel news-index-panel">
    <div class="section-title compact">
      <span>04</span>
      <div>
        <h2>新聞索引</h2>
        <p>每個 ticker 集中顯示對應新聞，先看同一檔股票的證據密度，再進個股頁查核。</p>
      </div>
    </div>

    {newsIndex.length > 0 ? (
      <div class="news-index-grid">
        {newsIndex.slice(0, 12).map((item) => (
          <article class="news-index-card">
            <header>
              <a class="ticker-name" href={tickerHref(item.ticker)}>
                <strong>{item.ticker}</strong>
                {tickerName(item) && <span>{tickerName(item)}</span>}
              </a>
              <em>{item.count} 則對應新聞</em>
            </header>
            <div class="headline-list">
              {item.headlines.slice(0, 4).map((headline) => (
                <a href={headline.link || tickerHref(item.ticker)} target={headline.link ? "_blank" : undefined} rel={headline.link ? "noopener" : undefined}>
                  <b>{headline.kind}</b>
                  <span>{plainTitle(headline.title)}</span>
                  <em>{headline.source} · {ago(headline.published)}</em>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p class="empty-state">目前沒有足夠的對應新聞索引。</p>
    )}
      </section>
    </div>

    <aside id="calls" class="calendar-rail">
      <div class="calendar-rail-inner">
        <div class="section-title compact">
          <span>02</span>
          <div>
            <h2>市場日曆</h2>
            <p>重要總經、法說與台美股事件排在同一張日曆，只留需要查核的公司與市場訊號。</p>
          </div>
        </div>

        {callCalendar ? (
          <>
            <div class="call-calendar" data-call-calendar aria-label="市場日曆：重要總經、法說、台美股事件">
              <header>
                <span>日曆圖</span>
                <strong>{callCalendar.label}</strong>
              </header>
              <div class="calendar-toolbar">
                <label class="calendar-search-wrap">
                  <span class="calendar-search-icon" aria-hidden="true">⌕</span>
                  <input
                    id="calendar-search-input"
                    class="calendar-search-input"
                    type="search"
                    placeholder="搜尋 ticker、公司名（中文/英文）、事件標題"
                    autocomplete="off"
                    spellcheck="false"
                  />
                  <button type="button" id="calendar-search-clear" class="calendar-search-clear" aria-label="清除搜尋" hidden>×</button>
                </label>
                <div class="calendar-search-mode" role="group" aria-label="搜尋模式">
                  <button type="button" class="calendar-mode-btn is-active" data-calendar-mode="highlight">高亮</button>
                  <button type="button" class="calendar-mode-btn" data-calendar-mode="filter">過濾</button>
                </div>
                <span id="calendar-search-summary" class="calendar-search-summary" aria-live="polite"></span>
              </div>
              <div class="calendar-legend">
                <span class="macro">重要總經</span>
                <span class="call">法說</span>
                <span class="tw-event">台股事件</span>
                <span class="us-event">美股事件</span>
              </div>
              <div class="calendar-weekdays">
                {callCalendar.weekdays.map((day) => <span>{day}</span>)}
              </div>
              <div class="calendar-grid">
                {callCalendar.days.map((day) => {
                  const signals = calendarSignalsForDay(day.events);
                  const VISIBLE_PER_DAY = 3;
                  const overflowCount = Math.max(0, day.events.length - VISIBLE_PER_DAY);
                  const dayPayload = day.events.map((event) => ({
                    kind: event.kind,
                    label: event.label,
                    title: calendarEventTitle(event),
                    fullTitle: event.title,
                    meta: calendarEventMeta(event),
                    href: itemHref(event),
                    external: Boolean(event.link),
                    haystack: [
                      event.ticker || "",
                      event.display_name || "",
                      event.label || "",
                      event.source || "",
                      event.title || "",
                    ].join(" ").toLowerCase(),
                  }));
                  return (
                    <div
                      class={`calendar-day ${day.inMonth ? "" : "outside"} ${signals.length ? "has-event" : ""}`}
                      data-iso={day.date}
                      data-events={dayPayload.length ? JSON.stringify(dayPayload) : undefined}
                    >
                      <time datetime={day.date}>{day.day}</time>
                      {signals.slice(0, VISIBLE_PER_DAY).map((event) => {
                        const haystack = [
                          event.ticker || "",
                          event.display_name || "",
                          event.label || "",
                          event.source || "",
                          event.title || "",
                        ].join(" ").toLowerCase();
                        return (
                          <a
                            class={`calendar-event ${calendarEventKindClass(event)}`}
                            href={itemHref(event)}
                            target={event.link ? "_blank" : undefined}
                            rel={event.link ? "noopener" : undefined}
                            data-search={haystack}
                            data-kind={event.kind}
                            title={event.title}
                          >
                            <em>{event.label}</em>
                            <strong>{calendarEventTitle(event)}</strong>
                          </a>
                        );
                      })}
                      {overflowCount > 0 && (
                        <button
                          type="button"
                          class="calendar-overflow-pill"
                          data-day-iso={day.date}
                          aria-label={`查看 ${day.date} 共 ${day.events.length} 則事件`}
                        >+{overflowCount} 更多</button>
                      )}
                    </div>
                  );
                })}
              </div>
              <dialog id="calendar-day-dialog" class="calendar-day-dialog" aria-labelledby="calendar-dialog-date">
                <header class="calendar-day-dialog-head">
                  <strong id="calendar-dialog-date"></strong>
                  <span id="calendar-dialog-count" class="calendar-dialog-count"></span>
                  <button type="button" class="calendar-dialog-close" aria-label="關閉" data-calendar-dialog-close>×</button>
                </header>
                <div id="calendar-dialog-events" class="calendar-day-dialog-body"></div>
              </dialog>
            </div>
            {callEvents.length > 0 && (
              <div class="event-list">
                {callEvents.slice(0, 12).map((item) => (
                  <a class="event-row" href={itemHref(item)} target={item.link ? "_blank" : undefined} rel={item.link ? "noopener" : undefined}>
                    <time>{dateLabel(item.event_date)}</time>
                    <span class="ticker-name">
                      <strong>{item.ticker}</strong>
                      {tickerName(item) && <span>{tickerName(item)}</span>}
                    </span>
                    <span>{plainTitle(item.title)}</span>
                    <em>{item.source} · {ago(item.published)}</em>
                  </a>
                ))}
              </div>
            )}
          </>
        ) : (
          <p class="empty-state">目前沒有可索引的市場日曆資料。</p>
        )}
      </div>
    </aside>
  </section>

  <section class="quick-ticker-grid" aria-label="stock shortcuts">
    {hotTickers.map((item) => (
      <a href={`/stocks/${item.ticker}/`} class="quick-ticker-card">
        <div>
          <strong>{item.ticker}</strong>
          <span>{marketLabel(item.market)}</span>
        </div>
        <p>{item.name || item.label}</p>
        <footer>
          <span>{item.articles} 篇新聞</span>
          <span>{item.reports} 份財報</span>
          <span>{item.momentum ? `熱度 +${item.momentum.delta}` : "熱度持平"}</span>
        </footer>
      </a>
    ))}
  </section>

  <section class="filing-strip">
    <span>公司原文</span>
    {filings.slice(0, 5).map((item) => (
      <a href={`/stocks/${item.ticker}/`}>
        <strong>{item.ticker}</strong>
        <em>{item.form_type} · {item.fiscal_year}{item.fiscal_period}</em>
      </a>
    ))}
    <span>{stockNews.length + internalStockFeed.length} 筆個股資料已索引</span>
  </section>

  <p class="disclaimer">
    本站整理公開資料，協助個股快速搜尋與交叉查證；資料可能延遲或缺漏，非投資建議。
  </p>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const tickers = window.__TICKERS__ || [];
      const input = document.getElementById("stock-command-input");
      const results = document.getElementById("stock-command-results");
      if (input && results) {
        const render = (matches) => {
          if (!matches.length) {
            results.innerHTML = '<div class="ticker-result-empty">沒有匹配，試試 2330、NVDA、TSM</div>';
            results.hidden = false;
            return;
          }
          results.innerHTML = matches.map((item) => {
            const market = item.m === "tw" ? "TW" : "US";
            const name = item.n ? `<span>${item.n}</span>` : "";
            return `<a href="/stocks/${item.t}/">
              <strong>${item.t}</strong>
              ${name}
              <em>${market} · ${item.a} 篇新聞${item.r ? ` · ${item.r} 份財報` : ""}</em>
            </a>`;
          }).join("");
          results.hidden = false;
        };
        const search = () => {
          const q = input.value.trim().toLowerCase();
          if (!q) {
            results.hidden = true;
            return;
          }
          const matches = tickers.filter((item) =>
            item.t.toLowerCase().includes(q) || (item.n && item.n.toLowerCase().includes(q))
          ).slice(0, 10);
          render(matches);
        };
        input.addEventListener("input", search);
        input.addEventListener("focus", search);
        input.addEventListener("keydown", (event) => {
          if (event.key === "Enter") {
            event.preventDefault();
            const first = results.querySelector("a");
            if (first) window.location.href = first.getAttribute("href");
            else if (input.value.trim()) window.location.href = `/stocks/${input.value.trim().toUpperCase()}/`;
          }
          if (event.key === "Escape") results.hidden = true;
        });
        input.addEventListener("blur", () => setTimeout(() => { results.hidden = true; }, 150));
      }

      const navLinks = document.querySelectorAll("#sec-nav a");
      const sections = ["research-guide", "calls", "estimates", "news-index"]
        .map((id) => document.getElementById(id))
        .filter(Boolean);
      const updateActive = () => {
        let current = sections[0]?.id;
        const top = window.scrollY + 160;
        for (const section of sections) if (section.offsetTop <= top) current = section.id;
        navLinks.forEach((link) => {
          link.toggleAttribute("data-current", link.getAttribute("data-target") === current);
        });
      };
      window.addEventListener("scroll", updateActive, { passive: true });
      updateActive();

      // === Market calendar: today/past/future tagging + IME-safe search ===
      const calendar = document.querySelector("[data-call-calendar]");
      if (calendar) {
        const todayIso = new Date().toISOString().slice(0, 10);
        calendar.querySelectorAll(".calendar-day[data-iso]").forEach((cell) => {
          const iso = cell.getAttribute("data-iso");
          if (!iso) return;
          if (iso === todayIso) cell.classList.add("is-today");
          else if (iso < todayIso) cell.classList.add("is-past");
          else cell.classList.add("is-future");
        });

        const searchInput = document.getElementById("calendar-search-input");
        const clearBtn = document.getElementById("calendar-search-clear");
        const summary = document.getElementById("calendar-search-summary");
        const modeBtns = calendar.querySelectorAll("[data-calendar-mode]");
        let searchMode = "highlight";
        let isComposing = false;
        let suppressNextInput = false;

        const allEvents = Array.from(calendar.querySelectorAll(".calendar-event[data-search]"));
        const allDays = Array.from(calendar.querySelectorAll(".calendar-day"));

        function applySearch(rawValue) {
          const q = String(rawValue || "").trim().toLowerCase();
          if (clearBtn) clearBtn.hidden = !q;
          let matched = 0;
          for (const evt of allEvents) {
            const hay = evt.getAttribute("data-search") || "";
            const hit = !q || hay.includes(q);
            evt.classList.toggle("is-match", Boolean(q) && hit);
            evt.classList.toggle("is-dim", Boolean(q) && !hit);
            evt.classList.toggle("is-hidden", searchMode === "filter" && Boolean(q) && !hit);
            if (q && hit) matched += 1;
          }
          for (const day of allDays) {
            const hasVisible = !q || day.querySelector(".calendar-event.is-match, .calendar-event:not(.is-hidden)");
            day.classList.toggle("is-search-empty", searchMode === "filter" && Boolean(q) && !day.querySelector(".calendar-event:not(.is-hidden)"));
          }
          if (summary) {
            summary.textContent = q ? `${matched} 則符合「${rawValue}」` : "";
          }
        }

        if (searchInput) {
          searchInput.addEventListener("compositionstart", () => {
            isComposing = true;
          });
          searchInput.addEventListener("compositionend", (event) => {
            isComposing = false;
            suppressNextInput = true;
            applySearch(event.target.value);
          });
          searchInput.addEventListener("input", (event) => {
            if (isComposing || event.isComposing) return;
            if (suppressNextInput) {
              suppressNextInput = false;
              return;
            }
            applySearch(event.target.value);
          });
          searchInput.addEventListener("keydown", (event) => {
            if (event.key === "Escape") {
              searchInput.value = "";
              applySearch("");
            }
          });
        }
        if (clearBtn && searchInput) {
          clearBtn.addEventListener("click", () => {
            searchInput.value = "";
            applySearch("");
            searchInput.focus();
          });
        }
        modeBtns.forEach((btn) => {
          btn.addEventListener("click", () => {
            modeBtns.forEach((b) => b.classList.toggle("is-active", b === btn));
            searchMode = btn.getAttribute("data-calendar-mode") || "highlight";
            applySearch(searchInput ? searchInput.value : "");
          });
        });

        // Day-detail dialog: pill click → populate + show all events for that day
        const dialog = document.getElementById("calendar-day-dialog");
        const dialogDate = document.getElementById("calendar-dialog-date");
        const dialogCount = document.getElementById("calendar-dialog-count");
        const dialogEvents = document.getElementById("calendar-dialog-events");
        const KIND_CLASS = {
          macro: "macro",
          call: "call",
          tw_event: "tw-event",
          us_event: "us-event",
        };
        function escapeHtml(value) {
          return String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");
        }
        function openDayDialog(iso) {
          if (!dialog || !dialogEvents || !iso) return;
          const cell = calendar.querySelector(`.calendar-day[data-iso="${iso}"]`);
          if (!cell) return;
          let payload = [];
          try {
            payload = JSON.parse(cell.getAttribute("data-events") || "[]");
          } catch (err) {
            payload = [];
          }
          if (dialogDate) dialogDate.textContent = iso;
          if (dialogCount) dialogCount.textContent = payload.length ? `共 ${payload.length} 則` : "";
          dialogEvents.innerHTML = payload.map((evt) => {
            const cls = KIND_CLASS[evt.kind] || "macro";
            const meta = evt.meta ? `<span class="dialog-event-meta">${escapeHtml(evt.meta)}</span>` : "";
            const target = evt.external ? ' target="_blank" rel="noopener"' : "";
            return `<a class="calendar-day-dialog-event ${cls}" href="${escapeHtml(evt.href)}"${target}>
              <span class="dialog-event-label">${escapeHtml(evt.label)}</span>
              <strong class="dialog-event-title">${escapeHtml(evt.fullTitle || evt.title)}</strong>
              ${meta}
            </a>`;
          }).join("");
          if (typeof dialog.showModal === "function") dialog.showModal();
          else dialog.setAttribute("open", "");
        }
        function closeDayDialog() {
          if (!dialog) return;
          if (typeof dialog.close === "function") dialog.close();
          else dialog.removeAttribute("open");
        }
        calendar.querySelectorAll(".calendar-overflow-pill").forEach((pill) => {
          pill.addEventListener("click", (event) => {
            event.preventDefault();
            event.stopPropagation();
            openDayDialog(pill.getAttribute("data-day-iso"));
          });
        });
        if (dialog) {
          dialog.addEventListener("click", (event) => {
            // Close when clicking the backdrop (the dialog element itself)
            if (event.target === dialog) closeDayDialog();
          });
          const closeBtn = dialog.querySelector("[data-calendar-dialog-close]");
          if (closeBtn) closeBtn.addEventListener("click", closeDayDialog);
        }
      }
    });
  </script>
</Base>
