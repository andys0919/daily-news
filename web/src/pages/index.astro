---
import Base from "../layouts/Base.astro";
import overview from "../data/overview.json";

interface Guidance { title: string; link: string; source: string; published: string; direction: string; excerpt: string; tickers: string[]; }
interface Fundamental {
  ticker: string; market: string; company_name: string | null;
  latest: any;
  health: { tier: string; label: string; summary: string; icon: string };
  guidance: { up: number; down: number; net: number };
}
interface Take { kind: string; headline: string; detail: string; }

const takeaways = (overview.takeaways ?? []) as Take[];
const fundamentals = (overview.fundamentals ?? []) as Fundamental[];
const guidanceUp = (overview.guidance_up ?? []) as Guidance[];
const guidanceDown = (overview.guidance_down ?? []) as Guidance[];
const stats: any = overview.stats ?? {};
const generated = overview.generated_at ?? "";

function ago(iso: string | undefined): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  const h = Math.floor((Date.now() - d.getTime()) / 3.6e6);
  if (h < 1) return "<1h";
  if (h < 24) return `${h}h`;
  return `${Math.floor(h / 24)}d`;
}
function plainTitle(t: string): string {
  return (t || "").split(" - ")[0].trim();
}

const tierOrder: Record<string, number> = { strong: 0, steady: 1, watch: 2, warn: 3, unknown: 4 };
const sortedFundamentals = [...fundamentals].sort((a, b) =>
  (tierOrder[a.health?.tier ?? "unknown"] ?? 5) - (tierOrder[b.health?.tier ?? "unknown"] ?? 5)
);
---
<Base title="今日 — 投資 dashboard" active="home">
  <header class="page-h">
    <div class="eyebrow">{generated.slice(0, 10)} · today</div>
    <h1>今日該看 <span class="accent">什麼</span></h1>
    <p>
      從過去 30 天 {(stats.articles_30d ?? 0).toLocaleString()} 篇新聞中濾出含「目標價變動 / 財測 / EPS beat 或 miss」事件，搭配 watchlist 基本面健康度，整理成下面 3 段。每段都是一句白話，不要看一堆數字才能判斷。
    </p>
  </header>

  <!-- 1. Takeaway — single big sentence each -->
  <section class="take-cards" style="margin-bottom: var(--s-10);">
    {takeaways.map((t) => (
      <div class={`take ${t.kind}`}>
        <div class="take-tag">{t.kind === "positive" ? "▲ 偏正面" : t.kind === "negative" ? "▼ 偏負面" : "─ 中性"}</div>
        <div class="take-headline">{t.headline}</div>
        <div class="take-detail">{t.detail}</div>
      </div>
    ))}
    {takeaways.length === 0 && (
      <div class="take neutral" style="grid-column: 1 / -1;">
        <div class="take-tag">─ pipeline 待跑</div>
        <div class="take-headline">尚未產生今日 takeaway</div>
      </div>
    )}
  </section>

  <!-- 2. Watchlist signals -->
  <div class="section-h2">
    <h2>Watchlist 健康度</h2>
    <span class="h-sub">🟢 強 · 🔵 穩 · 🟡 觀望 · 🔴 警示 · ⚫ 資料不足</span>
  </div>
  <aside class="howto">
    <div class="howto-icon">i</div>
    <div>
      <p class="howto-title">怎麼看健康度</p>
      <p class="howto-body">
        看 <strong>圖示 + 一句話</strong>就好。<strong>🟢 / 🔵</strong> 表示基本面健康（營收成長 + 高營益率），可以做長期持有候選。<strong>🟡 / 🔴</strong> 表示要先看新聞、釐清原因再判斷。<strong>⚫</strong> 表示資料尚未建檔（需執行 stock_memo.py 觸發財報抓取）。
      </p>
    </div>
  </aside>
  <section class="verdict-grid" style="margin-bottom: var(--s-10);">
    {sortedFundamentals.map((f) => {
      const h = f.health ?? { tier: "unknown", label: "—", summary: "", icon: "⚫" };
      const g = f.guidance ?? { up: 0, down: 0, net: 0 };
      return (
        <a href={`/stocks/${f.ticker}/`} class="verdict">
          <div class="verdict-icon">{h.icon ?? "⚫"}</div>
          <div class="verdict-body">
            <div class="verdict-head">
              <span class="t">{f.ticker}</span>
              <span class={`label ${h.tier}`}>{h.label}</span>
              {f.company_name && <span class="muted-2" style="font-size: var(--t-label);">{f.company_name}</span>}
            </div>
            <div class="verdict-summary">{h.summary || "—"}</div>
          </div>
          <div class="verdict-meta">
            {g.up + g.down > 0 ? (
              <>
                <div>
                  {g.up > 0 && <span class="pos">↑{g.up}</span>}
                  {g.up > 0 && g.down > 0 && " · "}
                  {g.down > 0 && <span class="neg">↓{g.down}</span>}
                </div>
                <div class="muted-2" style="font-size: var(--t-caption);">近 30 天</div>
              </>
            ) : (
              <div class="muted-2" style="font-size: var(--t-caption);">無新事件</div>
            )}
          </div>
        </a>
      );
    })}
  </section>

  <!-- 3. Up/Down flash -->
  <div class="section-h2">
    <h2>本週訊號速報</h2>
    <span class="h-sub">分析師 / 媒體口中的「上修」「下修」「目標價變動」</span>
    <a href="/guidance/" class="h-link">完整列表 →</a>
  </div>
  <aside class="howto">
    <div class="howto-icon">i</div>
    <div>
      <p class="howto-title">怎麼看上修 / 下修</p>
      <p class="howto-body">
        左欄 <strong>▲ 上修</strong>：標題出現「raises guidance」「lifts target」「上修目標價」「beats estimates」等明確正面事件。<br/>
        右欄 <strong>▼ 下修</strong>：標題出現「cuts guidance」「misses EPS」「下修財測」「slashes」等負面事件。<br/>
        只算<strong>標題</strong>的高精度短語，不算單純被提及，避免被新聞噪音帶風向。
      </p>
    </div>
  </aside>
  <section class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title"><span class="delta-up">▲</span> 上修 / Beat ({guidanceUp.length})</h2>
      </header>
      <div class="flash-list">
        {guidanceUp.slice(0, 7).map((g) => (
          <a class="flash" href={g.link} target="_blank" rel="noopener">
            <span class="flash-arrow up">▲</span>
            <div class="flash-text">
              {g.tickers.length > 0 && <span class="ticker">{g.tickers[0]}</span>}
              {plainTitle(g.title)}
            </div>
            <span class="flash-time">{ago(g.published)}</span>
          </a>
        ))}
        {guidanceUp.length === 0 && <p class="muted" style="padding: var(--s-4); font-size: var(--t-small);">（本週暫無上修事件）</p>}
      </div>
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title"><span class="delta-down">▼</span> 下修 / Miss ({guidanceDown.length})</h2>
      </header>
      <div class="flash-list">
        {guidanceDown.slice(0, 7).map((g) => (
          <a class="flash" href={g.link} target="_blank" rel="noopener">
            <span class="flash-arrow down">▼</span>
            <div class="flash-text">
              {g.tickers.length > 0 && <span class="ticker">{g.tickers[0]}</span>}
              {plainTitle(g.title)}
            </div>
            <span class="flash-time">{ago(g.published)}</span>
          </a>
        ))}
        {guidanceDown.length === 0 && <p class="muted" style="padding: var(--s-4); font-size: var(--t-small);">（本週暫無下修事件）</p>}
      </div>
    </article>
  </section>
</Base>
