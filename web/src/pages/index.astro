---
import Base from "../layouts/Base.astro";
import overview from "../data/overview.json";

interface Mention { ticker: string; mentions: number; last_seen: string }
interface MomentumRow { ticker: string; mentions_7d: number; mentions_prior_7d: number; delta: number; pct_change: number }
interface Theme { theme: string; count: number; examples: any[] }
interface NewsItem { title: string; link: string; source: string; category: string; published: string; tickers: string[]; event_type?: string; summary?: string }

const stats: any = overview.stats ?? {};
const topTickers7 = (overview.top_tickers_7d ?? []) as Mention[];
const themes = (overview.themes ?? []) as Theme[];
const momentum = (overview.momentum ?? []) as MomentumRow[];
const categories = (overview.categories ?? []) as { category: string; count: number; pct: number }[];
const velocity = overview.velocity ?? { days: [], totals: [], by_category: {} };
const clusters = overview.event_clusters ?? {};
const watchlist = (overview.watchlist ?? []) as string[];
const earnings = ((clusters as any).earnings ?? []) as NewsItem[];
const capex = ((clusters as any).capex ?? []) as NewsItem[];
const policy = ((clusters as any).policy ?? []) as NewsItem[];
const generatedAt = overview.generated_at ?? "";
const generatedDay = generatedAt.slice(0, 10);
const generatedTime = generatedAt.slice(11, 16);

function fmtInt(n: number | undefined): string {
  if (typeof n !== "number") return "—";
  return n.toLocaleString("en-US");
}
function ago(iso: string | undefined): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  const diff = Date.now() - d.getTime();
  const m = Math.floor(diff / 60000);
  if (m < 60) return `${Math.max(1, m)}m`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h`;
  return `${Math.floor(h / 24)}d`;
}

const days = (velocity.days ?? []) as string[];
const totals = (velocity.totals ?? []) as number[];
const maxTotal = Math.max(1, ...totals);
const w = 320, h = 60, pad = 6;
const stepX = days.length > 1 ? (w - 2 * pad) / (days.length - 1) : 0;
const pts = totals.map((v, i) => `${pad + i * stepX},${h - pad - (v / maxTotal) * (h - 2 * pad)}`);
const areaPath = pts.length > 0 ? `M${pts[0]} L${pts.join(" L")} L${pad + (totals.length - 1) * stepX},${h - pad} L${pad},${h - pad} Z` : "";
const linePath = pts.length > 0 ? `M${pts.join(" L")}` : "";

const catRows = categories.slice(0, 8);
const maxCat = catRows.length > 0 ? Math.max(...catRows.map((c) => c.count)) : 1;
const velocityAvg = totals.length ? Math.round(totals.reduce((a, b) => a + b, 0) / totals.length) : 0;
---
<Base title="Investment Dashboard — 投資決策總覽">
  <section class="hero">
    <div>
      <span class="live"><span class="live-dot"></span>live · {fmtInt(stats.articles_24h)} 篇/24h</span>
      <h1 class="mt-2">
        盤前 <span class="accent">訊號掃描</span>
      </h1>
      <p class="hero-sub">
        過去 30 天彙整 <strong class="mono">{fmtInt(stats.articles_30d)}</strong> 篇新聞 · 追蹤 <strong class="mono">{fmtInt(stats.tickers_tracked)}</strong> 檔個股 · <strong class="mono">{fmtInt(stats.reports_total)}</strong> 份官方財報。每天 09:00 由 daily-news pipeline 自動刷新。
      </p>
    </div>
    <div class="hero-meta">
      <div><span class="ts mono">{generatedDay}</span></div>
      <div class="mono">{generatedTime}Z · UTC</div>
      <div class="mt-1">watchlist <span class="mono">{watchlist.length}</span></div>
    </div>
  </section>

  <section class="stats-strip mb-6">
    <div class="stat"><div class="stat-label">24h news</div><div class="stat-value">{fmtInt(stats.articles_24h)}</div><div class="stat-sub">最新一日</div></div>
    <div class="stat"><div class="stat-label">7d news</div><div class="stat-value">{fmtInt(stats.articles_7d)}</div><div class="stat-sub">本週累計</div></div>
    <div class="stat"><div class="stat-label">30d news</div><div class="stat-value">{fmtInt(stats.articles_30d)}</div><div class="stat-sub">月內動態</div></div>
    <div class="stat"><div class="stat-label">Reports</div><div class="stat-value">{fmtInt(stats.reports_total)}</div><div class="stat-sub">官方財報</div></div>
    <div class="stat"><div class="stat-label">Tickers</div><div class="stat-value">{fmtInt(stats.tickers_tracked)}</div><div class="stat-sub">已建檔個股</div></div>
    <div class="stat"><div class="stat-label">All-time</div><div class="stat-value">{fmtInt(stats.articles_total)}</div><div class="stat-sub">累計</div></div>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-4">
    <article class="glass bento lg:col-span-2">
      <header class="bento-head">
        <h2 class="bento-title">本週動能榜 · Mention Momentum</h2>
        <a href="/screens" class="bento-link">全部 screen →</a>
      </header>
      <div class="lb">
        {momentum.slice(0, 12).map((m, i) => (
          <a class="lb-row" href={`/stocks/${m.ticker}`}>
            <div style="display:flex; align-items:baseline; gap:10px;">
              <span class="rank mono">#{(i + 1).toString().padStart(2, "0")}</span>
              <span class="name mono"><strong>{m.ticker}</strong></span>
            </div>
            <span class="v">{m.mentions_7d} 篇</span>
            <span class={`delta ${m.delta > 0 ? "up" : m.delta < 0 ? "down" : "flat"}`}>{m.delta >= 0 ? "+" : ""}{m.delta}</span>
          </a>
        ))}
        {momentum.length === 0 && <p class="muted text-sm">（暫無資料）</p>}
      </div>
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">7 天熱門 ticker</h2>
        <span class="bento-link mono">top {topTickers7.length}</span>
      </header>
      <div class="lb">
        {topTickers7.slice(0, 12).map((t, i) => (
          <a class="lb-row" href={`/stocks/${t.ticker}`}>
            <div style="display:flex; align-items:baseline; gap:10px;">
              <span class="rank mono">#{(i + 1).toString().padStart(2, "0")}</span>
              <span class="name mono"><strong>{t.ticker}</strong></span>
            </div>
            <span class="v">{t.mentions}</span>
            <span class="delta flat mono">{t.last_seen}</span>
          </a>
        ))}
      </div>
    </article>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-4">
    <article class="glass bento lg:col-span-2">
      <header class="bento-head">
        <h2 class="bento-title">News velocity · 14 天</h2>
        <span class="bento-link mono">avg {velocityAvg}/day</span>
      </header>
      <svg class="spark" viewBox={`0 0 ${w} ${h}`} preserveAspectRatio="none">
        <path class="area" d={areaPath} />
        <path class="line" d={linePath} />
        {pts.map((p) => {
          const [x, y] = p.split(",").map(Number);
          return <circle class="dot" cx={x} cy={y} r="2" />;
        })}
      </svg>
      <div style="display:flex; justify-content:space-between; margin-top:6px;">
        <span class="muted-2 mono" style="font-size:10px;">{days[0] ?? ""}</span>
        <span class="muted-2 mono" style="font-size:10px;">{days[days.length - 1] ?? ""}</span>
      </div>
      <div class="mt-4">
        {catRows.map((c) => (
          <div class="cat-row">
            <div class="lbl" style="min-width:0;">
              <div class="lbl-text">{c.category}</div>
              <div class="bar"><div class="bar-fill" style={`width:${Math.max(2, (c.count / maxCat) * 100)}%`}></div></div>
            </div>
            <span class="v">{c.count} · {c.pct}%</span>
          </div>
        ))}
      </div>
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">主題熱度 · 30 天</h2>
        <a href="/themes" class="bento-link">展開 →</a>
      </header>
      <div class="theme-cloud">
        {themes.slice(0, 10).map((t, i) => (
          <a href={`/themes#${encodeURIComponent(t.theme)}`} class={`theme-chip ${i < 3 ? "hot" : ""}`}>
            <span>{t.theme}</span>
            <span class="n">{t.count}</span>
          </a>
        ))}
        {themes.length === 0 && <p class="muted text-sm">（暫無主題）</p>}
      </div>
      <h2 class="bento-title" style="margin-top:18px; margin-bottom:10px;">Watchlist</h2>
      <div class="watchgrid">
        {watchlist.map((t) => (
          <a href={`/stocks/${t.toUpperCase()}`} class="watchcell">
            <span class="t">{t.toUpperCase()}</span>
            <span class="m">{t.match(/^\d+$/) ? "TW" : "US"}</span>
          </a>
        ))}
      </div>
    </article>
  </section>

  <section class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-4">
    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">📊 法說 / 財報相關</h2>
        <span class="bento-link mono">{earnings.length}</span>
      </header>
      <div class="signals">
        {earnings.slice(0, 6).map((e) => (
          <a class="signal" href={e.link} target="_blank" rel="noopener">
            <span class="signal-tag transcript">earn</span>
            <div class="signal-body">
              <div class="line-clamp-2">{e.title}</div>
              <div class="meta">{e.source} · {e.tickers && e.tickers.length > 0 ? e.tickers.slice(0, 3).join(", ") : ""}</div>
            </div>
            <span class="signal-meta">{ago(e.published)}</span>
          </a>
        ))}
        {earnings.length === 0 && <p class="muted text-sm">（無資料）</p>}
      </div>
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">🏗 資本支出 / 擴產</h2>
        <span class="bento-link mono">{capex.length}</span>
      </header>
      <div class="signals">
        {capex.slice(0, 6).map((e) => (
          <a class="signal" href={e.link} target="_blank" rel="noopener">
            <span class="signal-tag holdings">capex</span>
            <div class="signal-body">
              <div class="line-clamp-2">{e.title}</div>
              <div class="meta">{e.source} · {e.tickers && e.tickers.length > 0 ? e.tickers.slice(0, 3).join(", ") : ""}</div>
            </div>
            <span class="signal-meta">{ago(e.published)}</span>
          </a>
        ))}
        {capex.length === 0 && <p class="muted text-sm">（無資料）</p>}
      </div>
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">🏛 政策 / 監管</h2>
        <span class="bento-link mono">{policy.length}</span>
      </header>
      <div class="signals">
        {policy.slice(0, 6).map((e) => (
          <a class="signal" href={e.link} target="_blank" rel="noopener">
            <span class="signal-tag insider">policy</span>
            <div class="signal-body">
              <div class="line-clamp-2">{e.title}</div>
              <div class="meta">{e.source} · {e.tickers && e.tickers.length > 0 ? e.tickers.slice(0, 3).join(", ") : ""}</div>
            </div>
            <span class="signal-meta">{ago(e.published)}</span>
          </a>
        ))}
        {policy.length === 0 && <p class="muted text-sm">（無資料）</p>}
      </div>
    </article>
  </section>

  <section class="grid grid-cols-2 lg:grid-cols-4 gap-3">
    <a href="/news" class="glass bento" style="padding:14px;">
      <div class="bento-title">📰 新聞時間軸</div>
      <div style="margin-top:8px; color: var(--fg-200); font-size: 13px;">300 篇最新文章 · 多分類篩選</div>
    </a>
    <a href="/screens" class="glass bento" style="padding:14px;">
      <div class="bento-title">🎯 投資 screen</div>
      <div style="margin-top:8px; color: var(--fg-200); font-size: 13px;">動能 / 主題 / 事件聚類</div>
    </a>
    <a href="/coverage" class="glass bento" style="padding:14px;">
      <div class="bento-title">🗺 覆蓋地圖</div>
      <div style="margin-top:8px; color: var(--fg-200); font-size: 13px;">{fmtInt(stats.tickers_tracked)} 檔個股資料</div>
    </a>
    <a href="/calendar" class="glass bento" style="padding:14px;">
      <div class="bento-title">📅 事件日曆</div>
      <div style="margin-top:8px; color: var(--fg-200); font-size: 13px;">earnings · capex · policy</div>
    </a>
  </section>
</Base>
