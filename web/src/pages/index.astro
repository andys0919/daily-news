---
import Base from "../layouts/Base.astro";
import overview from "../data/overview.json";

interface Guidance {
  title: string; link: string; source: string; published: string;
  direction: string; excerpt: string; tickers: string[];
}
interface Fundamental {
  ticker: string; market: string; company_name: string | null;
  latest: any;
  health: { tier: string; label: string; summary: string; icon: string; score?: number };
  guidance: { up: number; down: number; net: number };
}
interface Take {
  kind: string; headline: string; detail: string;
}

const takeaways = (overview.takeaways ?? []) as Take[];
const fundamentals = (overview.fundamentals ?? []) as Fundamental[];
const guidanceUp = (overview.guidance_up ?? []) as Guidance[];
const guidanceDown = (overview.guidance_down ?? []) as Guidance[];
const stats: any = overview.stats ?? {};
const watchlist = (overview.watchlist ?? []) as string[];
const generated = overview.generated_at ?? "";

function ago(iso: string | undefined): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  const h = Math.floor((Date.now() - d.getTime()) / 3.6e6);
  if (h < 1) return "<1h";
  if (h < 24) return `${h}h`;
  return `${Math.floor(h / 24)}d`;
}
function plainTitle(t: string): string {
  return (t || "").split(" - ")[0].trim();
}

// Sort watchlist: strong → steady → watch → warn → unknown
const tierOrder: Record<string, number> = { strong: 0, steady: 1, watch: 2, warn: 3, unknown: 4 };
const sortedFundamentals = [...fundamentals].sort((a, b) =>
  (tierOrder[a.health?.tier ?? "unknown"] ?? 5) - (tierOrder[b.health?.tier ?? "unknown"] ?? 5)
);
---
<Base title="Investment Dashboard" active="home">
  <!-- Hero ─────────────────────────────────────────────────────── -->
  <section class="hero">
    <div>
      <span class="live"><span class="live-dot"></span>{generated.slice(0, 10)}</span>
      <h1 class="mt-2">今天該看 <span class="accent">什麼</span></h1>
      <p class="hero-sub">
        從 30 天 {(stats.articles_30d ?? 0).toLocaleString()} 篇新聞濾出含「目標價 / 財測 / EPS beat 或 miss」的關鍵事件，搭配 watchlist 基本面健康度，
        替你濃縮成下面 3 句話。
      </p>
    </div>
    <div class="hero-meta">
      <div>watchlist <span class="ts mono">{watchlist.length}</span></div>
      <div>guidance 事件 <span class="ts mono">{stats.guidance_30d ?? 0}</span></div>
    </div>
  </section>

  <!-- 今日 3 takeaway ───────────────────────────────────────── -->
  <section class="take-cards mb-2">
    {takeaways.map((t) => (
      <div class={`take ${t.kind}`}>
        <div class="take-tag">{t.kind === "positive" ? "▲ 偏正面" : t.kind === "negative" ? "▼ 偏負面" : "─ 中性"}</div>
        <div class="take-headline">{t.headline}</div>
        <div class="take-detail">{t.detail}</div>
      </div>
    ))}
    {takeaways.length === 0 && (
      <div class="take neutral" style="grid-column: 1 / -1;">
        <div class="take-tag">─ 待跑 pipeline</div>
        <div class="take-headline">尚未產生今日 takeaway</div>
        <div class="take-detail">執行 dashboard_export.py 後會出現。</div>
      </div>
    )}
  </section>

  <!-- Watchlist 訊號燈 ────────────────────────────────────── -->
  <header class="section-h">
    <h2>Watchlist 健康度</h2>
    <span class="sub">🟢 強勢　🔵 穩健　🟡 觀望　🔴 警示　⚫ 資料不足</span>
  </header>
  <section class="verdict-grid mb-2">
    {sortedFundamentals.map((f) => {
      const l = f.latest;
      const h = f.health ?? { tier: "unknown", label: "—", summary: "" };
      const g = f.guidance ?? { up: 0, down: 0, net: 0 };
      return (
        <a href={`/stocks/${f.ticker}`} class="verdict">
          <div class="verdict-icon">{h.icon ?? "⚫"}</div>
          <div class="verdict-body">
            <div class="verdict-head">
              <span class="t">{f.ticker}</span>
              <span class={`label ${h.tier}`}>{h.label}</span>
              {f.company_name && <span class="muted-2" style="font-size: 11px;">{f.company_name}</span>}
            </div>
            <div class="verdict-summary">{h.summary || "—"}</div>
          </div>
          <div class="verdict-meta">
            {g.up + g.down > 0 ? (
              <>
                <div>
                  {g.up > 0 && <span class="pos">↑{g.up}</span>}
                  {g.up > 0 && g.down > 0 && " · "}
                  {g.down > 0 && <span class="neg">↓{g.down}</span>}
                </div>
                <div class="muted-2" style="font-size: 10px;">近 30 天</div>
              </>
            ) : (
              <div class="muted-2">無新事件</div>
            )}
          </div>
        </a>
      );
    })}
  </section>

  <!-- 上修 / 下修 速報 ─────────────────────────────────────── -->
  <header class="section-h">
    <h2>本週訊號速報</h2>
    <span class="sub">分析師與媒體口中的「上修」「下修」「目標價變動」</span>
  </header>
  <section class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-2">
    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title"><span class="delta-up">▲</span> 上修 / Beat ({guidanceUp.length})</h2>
        <a href="/guidance" class="bento-link">更多 →</a>
      </header>
      <div class="flash-list">
        {guidanceUp.slice(0, 7).map((g) => (
          <a class="flash" href={g.link} target="_blank" rel="noopener">
            <span class="flash-arrow up">▲</span>
            <div class="flash-text">
              {g.tickers.length > 0 && <span class="ticker">{g.tickers[0]}</span>}
              {plainTitle(g.title)}
            </div>
            <span class="flash-time">{ago(g.published)}</span>
          </a>
        ))}
        {guidanceUp.length === 0 && <p class="muted text-sm" style="padding:14px 4px;">（本週暫無上修事件）</p>}
      </div>
    </article>

    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title"><span class="delta-down">▼</span> 下修 / Miss ({guidanceDown.length})</h2>
        <a href="/guidance" class="bento-link">更多 →</a>
      </header>
      <div class="flash-list">
        {guidanceDown.slice(0, 7).map((g) => (
          <a class="flash" href={g.link} target="_blank" rel="noopener">
            <span class="flash-arrow down">▼</span>
            <div class="flash-text">
              {g.tickers.length > 0 && <span class="ticker">{g.tickers[0]}</span>}
              {plainTitle(g.title)}
            </div>
            <span class="flash-time">{ago(g.published)}</span>
          </a>
        ))}
        {guidanceDown.length === 0 && <p class="muted text-sm" style="padding:14px 4px;">（本週暫無下修事件）</p>}
      </div>
    </article>
  </section>

  <!-- 怎麼讀（圖例） ─────────────────────────────────────────── -->
  <article class="glass bento" style="margin-top: 28px;">
    <header class="bento-head">
      <h2 class="bento-title">怎麼讀這頁</h2>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" style="font-size: 13px; color: var(--fg-300); line-height: 1.7;">
      <div>
        <p style="color: var(--fg-100); font-weight: 500; margin-bottom: 6px;">健康度怎麼算？</p>
        <ul style="list-style: disc; padding-left: 18px;">
          <li>營收年增 ≥ 20% = 強，10-20% = 健康，0-10% = 平，&lt; 0 = 走弱</li>
          <li>營益率 ≥ 30% = 業界頂尖，15-30% = 健康，&lt; 15% = 偏低</li>
          <li>4 分以上 🟢 強勢，2-3 分 🔵 穩健，0-1 分 🟡 觀望，&lt; 0 🔴 警示</li>
        </ul>
      </div>
      <div>
        <p style="color: var(--fg-100); font-weight: 500; margin-bottom: 6px;">上修 / 下修怎麼算？</p>
        <ul style="list-style: disc; padding-left: 18px;">
          <li>標題出現 「上修目標價」「raises guidance」「lifts target」「beats estimates」「上看」等高精度短語</li>
          <li>下修：「cuts guidance」「misses EPS」「下修財測」「slashes」</li>
          <li><strong>不是</strong>分析師個人意見、<strong>不是</strong>媒體推測——是直接事件</li>
          <li>本工具僅彙整公開資訊，<strong>非投資建議</strong></li>
        </ul>
      </div>
    </div>
  </article>
</Base>
