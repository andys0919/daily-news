---
import Base from "../layouts/Base.astro";
import overview from "../data/overview.json";
import screens from "../data/screens.json";
import newsData from "../data/news.json";
import tickerIndex from "../data/tickers.json";

interface Article {
  title: string;
  link: string | null;
  source: string;
  published: string;
  tickers: string[];
  event_type: string | null;
  category?: string;
}
interface Analyst {
  title: string;
  link: string;
  source: string;
  published: string;
  tickers: string[];
  direction: string | null;
}
interface FilingExcerpt {
  ticker: string;
  company_name: string;
  fiscal_year: number;
  fiscal_period: string;
  form_type: string;
  excerpt: string;
}
interface Fundamental {
  ticker: string;
  market: string;
  company_name: string | null;
  latest: { revenue?: number | null; eps?: number | null; rev_yoy?: number | null } | null;
  health?: { tier: string; label: string; summary: string };
}
interface MomentumRow {
  ticker: string;
  mentions_7d: number;
  mentions_prior_7d: number;
  delta: number;
  pct_change: number;
}
interface TickerEntry {
  ticker: string;
  name: string;
  market: string;
  articles: number;
  reports: number;
  label: string;
}

const stats: any = overview.stats ?? {};
const generated = overview.generated_at ?? "";
const articles = ((newsData as any).articles ?? []) as Article[];
const analystViews = (overview.analyst_views ?? []) as Analyst[];
const fundamentals = (overview.fundamentals ?? []) as Fundamental[];
const filings = (overview.filing_excerpts ?? []) as FilingExcerpt[];
const internalFeed = (overview.internal_feed ?? []) as Article[];
const momentumRows = ((screens as any).momentum ?? []) as MomentumRow[];
const stockSearchItems = ((tickerIndex as any).tickers ?? []) as TickerEntry[];

const momentumByTicker: Record<string, MomentumRow> = {};
for (const row of momentumRows) momentumByTicker[row.ticker] = row;

function isStockSurfaceArticle(item: Article): boolean {
  if (!(item.tickers ?? []).length) return false;
  return !/github trending|arxiv|reddit r\/|hackernews|hugging face|sec form [345]|lobsters|servethehome/i.test(item.source || "");
}

const stockNews = articles.filter(isStockSurfaceArticle);
const callArticles = stockNews.filter((item) =>
  /transcript|earnings call|conference call|prepared remarks|法說|電話會議/i.test(`${item.title} ${item.source} ${item.category}`)
);
const internalStockFeed = internalFeed.filter(isStockSurfaceArticle);
const topSearchItems = stockSearchItems.slice(0, 12);
const hotTickers = topSearchItems
  .map((item) => ({ ...item, momentum: momentumByTicker[item.ticker] ?? null }))
  .sort((a, b) => (b.momentum?.delta ?? 0) - (a.momentum?.delta ?? 0) || b.articles - a.articles)
  .slice(0, 12);

function ago(iso: string | undefined): string {
  if (!iso) return "無時間";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso.slice(0, 10);
  const h = Math.floor((Date.now() - d.getTime()) / 3.6e6);
  if (h < 1) return "<1h";
  if (h < 24) return `${h}h`;
  return `${Math.floor(h / 24)}d`;
}

function plainTitle(title: string): string {
  return (title || "").split(" - ")[0].replace(/\s+/g, " ").trim();
}

function marketLabel(market: string): string {
  return market === "tw" ? "TW" : "US";
}

function fmtMoney(n: number | null | undefined, market: string): string {
  if (n == null || !Number.isFinite(Number(n))) return "缺資料";
  if (market === "tw") {
    const yi = Number(n) / 1e5;
    return `NT$${yi >= 10000 ? (yi / 10000).toFixed(1) + "兆" : Math.round(yi).toLocaleString() + "億"}`;
  }
  return `$${(Number(n) / 1e9).toFixed(1)}B`;
}

function tickerHref(ticker: string | undefined): string {
  return ticker ? `/stocks/${ticker}/` : "#";
}

function articleHref(item: Article | Analyst): string {
  return item.link || tickerHref(item.tickers?.[0]);
}

const sourceTiles = [
  { label: "即時新聞", value: stats.articles_24h ?? 0, sub: `${stats.articles_7d ?? 0} 篇 / 7 日`, tone: "news" },
  { label: "法人 / 分析師", value: analystViews.length, sub: "評等、目標價、機構觀點", tone: "analyst" },
  { label: "財報", value: stats.reports_total ?? 0, sub: "SEC / TWSE / MOPS / TPEx", tone: "financials" },
  { label: "電話會議", value: callArticles.length, sub: "transcript / earnings call", tone: "calls" },
];
---
<Base title="個股快搜 · Daily-News" active="home">
  <section class="search-hero">
    <div class="search-hero-copy">
      <span class="portal-kicker">即時個股資訊入口 · {generated.slice(0, 10)} · {ago(generated)} ago</span>
      <h1>個股快搜</h1>
      <p>
        這裡是個股相關資訊的快速搜尋網站：輸入 ticker 或公司名，就能進到個股頁看即時新聞、法人 / 分析師、財報、電話會議、公司原文與相關標的。idea-generation 只用來幫你排序熱門入口，不替你下買賣結論。
      </p>

      <div class="stock-command">
        <span class="command-icon">⌕</span>
        <input
          id="stock-command-input"
          type="text"
          placeholder="快速搜尋 2330、NVDA、台積電、NVIDIA..."
          autocomplete="off"
          spellcheck="false"
        />
        <kbd class="kbd">Enter</kbd>
        <div id="stock-command-results" class="ticker-result-list" hidden></div>
      </div>

      <div class="quick-strip" aria-label="popular ticker shortcuts">
        <span>熱門快搜</span>
        {topSearchItems.slice(0, 8).map((item) => (
          <a href={`/stocks/${item.ticker}/`}>{item.ticker}</a>
        ))}
      </div>
    </div>

    <div class="coverage-grid">
      {sourceTiles.map((tile) => (
        <a class={`coverage-card ${tile.tone}`} href={`#${tile.tone}`}>
          <span>{tile.label}</span>
          <strong>{tile.value}</strong>
          <em>{tile.sub}</em>
        </a>
      ))}
    </div>
  </section>

  <nav class="sec-index" id="sec-nav">
    <a href="#quick-search" data-target="quick-search">快速搜尋</a>
    <a href="#hot" data-target="hot">熱門快搜</a>
    <a href="#sources" data-target="sources">相關資料入口</a>
    <a href="#latest" data-target="latest">最新資料流</a>
  </nav>

  <section id="quick-search">
    <div class="section-title compact">
      <span>01</span>
      <div>
        <h2>快速搜尋</h2>
        <p>先從 ticker 進個股頁，再看新聞、法人、財報、電話會議與公司原文。</p>
      </div>
    </div>

    <div class="quick-ticker-grid">
      {hotTickers.map((item) => (
        <a href={`/stocks/${item.ticker}/`} class="quick-ticker-card">
          <div>
            <strong>{item.ticker}</strong>
            <span>{marketLabel(item.market)}</span>
          </div>
          <p>{item.name || item.label}</p>
          <footer>
            <span>{item.articles} 篇新聞</span>
            <span>{item.reports} 份財報</span>
            <span>{item.momentum ? `熱度 +${item.momentum.delta}` : "熱度持平"}</span>
          </footer>
        </a>
      ))}
    </div>
  </section>

  <section id="hot">
    <div class="section-title compact">
      <span>02</span>
      <div>
        <h2>熱門快搜</h2>
        <p>用 idea-generation 的思路把新聞熱度與資料覆蓋排在前面，方便快速打開個股頁查證。</p>
      </div>
    </div>

    <div class="ticker-rank-list">
      {momentumRows.slice(0, 10).map((item, index) => (
        <a href={`/stocks/${item.ticker}/`}>
          <b>{String(index + 1).padStart(2, "0")}</b>
          <strong>{item.ticker}</strong>
          <span>7 日提及 {item.mentions_7d} 次</span>
          <em>較前期 +{item.delta} / {item.pct_change >= 100 ? "突然升溫" : `${item.pct_change.toFixed(1)}%`}</em>
        </a>
      ))}
    </div>
  </section>

  <section id="sources">
    <div class="section-title compact">
      <span>03</span>
      <div>
        <h2>相關資料入口</h2>
        <p>把同一檔股票常用的資料來源拆開：新聞、法人、財報、電話會議。</p>
      </div>
    </div>

    <div class="source-lane-grid">
      <section class="source-lane" id="news">
        <header>
          <span>即時新聞</span>
          <b>{stockNews.length}</b>
        </header>
        {stockNews.slice(0, 8).map((item) => (
          <a href={articleHref(item)} target={item.link ? "_blank" : undefined} rel={item.link ? "noopener" : undefined}>
            <strong>{item.tickers[0]}</strong>
            <span>{plainTitle(item.title)}</span>
            <em>{item.source} · {ago(item.published)}</em>
          </a>
        ))}
      </section>

      <section class="source-lane" id="analyst">
        <header>
          <span>法人 / 分析師</span>
          <b>{analystViews.length}</b>
        </header>
        {analystViews.slice(0, 8).map((item) => (
          <a href={articleHref(item)} target="_blank" rel="noopener">
            <strong>{item.tickers[0] ?? "市場"}</strong>
            <span>{plainTitle(item.title)}</span>
            <em>{item.source} · {ago(item.published)}</em>
          </a>
        ))}
        {analystViews.length === 0 && <p class="empty-state">目前沒有法人 / 分析師資料。</p>}
      </section>

      <section class="source-lane" id="financials">
        <header>
          <span>財報</span>
          <b>{stats.reports_total ?? fundamentals.length}</b>
        </header>
        {fundamentals.slice(0, 8).map((item) => (
          <a href={`/stocks/${item.ticker}/`}>
            <strong>{item.ticker}</strong>
            <span>{item.company_name || item.ticker}</span>
            <em>{fmtMoney(item.latest?.revenue, item.market)} · EPS {item.latest?.eps ?? "缺資料"} · {item.health?.label ?? "資料不足"}</em>
          </a>
        ))}
      </section>

      <section class="source-lane" id="calls">
        <header>
          <span>電話會議</span>
          <b>{callArticles.length}</b>
        </header>
        {callArticles.slice(0, 8).map((item) => (
          <a href={articleHref(item)} target={item.link ? "_blank" : undefined} rel={item.link ? "noopener" : undefined}>
            <strong>{item.tickers[0] ?? "CALL"}</strong>
            <span>{plainTitle(item.title)}</span>
            <em>{item.source} · {ago(item.published)}</em>
          </a>
        ))}
        {callArticles.length === 0 && <p class="empty-state">目前沒有電話會議 transcript 文章。</p>}
      </section>
    </div>
  </section>

  <section id="latest">
    <div class="section-title compact">
      <span>04</span>
      <div>
        <h2>最新資料流</h2>
        <p>最近進來的個股資料，點 ticker 或標題就能回到相關來源。</p>
      </div>
    </div>

    <div class="latest-feed">
      {[...stockNews, ...internalStockFeed].slice(0, 14).map((item) => (
        <a href={articleHref(item)} target={item.link ? "_blank" : undefined} rel={item.link ? "noopener" : undefined}>
          <time>{ago(item.published)}</time>
          <strong>{item.tickers?.[0] ?? "市場"}</strong>
          <span>{plainTitle(item.title)}</span>
          <em>{item.source}</em>
        </a>
      ))}
    </div>
  </section>

  <section class="filing-strip">
    <span>公司原文</span>
    {filings.slice(0, 5).map((item) => (
      <a href={`/stocks/${item.ticker}/`}>
        <strong>{item.ticker}</strong>
        <em>{item.form_type} · {item.fiscal_year}{item.fiscal_period}</em>
      </a>
    ))}
  </section>

  <p class="disclaimer">
    本站整理公開資料，協助個股快速搜尋與交叉查證；資料可能延遲或缺漏，非投資建議。
  </p>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const tickers = window.__TICKERS__ || [];
      const input = document.getElementById("stock-command-input");
      const results = document.getElementById("stock-command-results");
      if (input && results) {
        const render = (matches) => {
          if (!matches.length) {
            results.innerHTML = '<div class="ticker-result-empty">沒有匹配，試試 2330、NVDA、TSM</div>';
            results.hidden = false;
            return;
          }
          results.innerHTML = matches.map((item) => {
            const market = item.m === "tw" ? "TW" : "US";
            const name = item.n ? `<span>${item.n}</span>` : "";
            return `<a href="/stocks/${item.t}/">
              <strong>${item.t}</strong>
              ${name}
              <em>${market} · ${item.a} 篇新聞${item.r ? ` · ${item.r} 份財報` : ""}</em>
            </a>`;
          }).join("");
          results.hidden = false;
        };
        const search = () => {
          const q = input.value.trim().toLowerCase();
          if (!q) {
            results.hidden = true;
            return;
          }
          const matches = tickers.filter((item) =>
            item.t.toLowerCase().includes(q) || (item.n && item.n.toLowerCase().includes(q))
          ).slice(0, 10);
          render(matches);
        };
        input.addEventListener("input", search);
        input.addEventListener("focus", search);
        input.addEventListener("keydown", (event) => {
          if (event.key === "Enter") {
            event.preventDefault();
            const first = results.querySelector("a");
            if (first) window.location.href = first.getAttribute("href");
            else if (input.value.trim()) window.location.href = `/stocks/${input.value.trim().toUpperCase()}/`;
          }
          if (event.key === "Escape") results.hidden = true;
        });
        input.addEventListener("blur", () => setTimeout(() => { results.hidden = true; }, 150));
      }

      const navLinks = document.querySelectorAll("#sec-nav a");
      const sections = ["quick-search", "hot", "sources", "latest"]
        .map((id) => document.getElementById(id))
        .filter(Boolean);
      const updateActive = () => {
        let current = sections[0]?.id;
        const top = window.scrollY + 160;
        for (const section of sections) if (section.offsetTop <= top) current = section.id;
        navLinks.forEach((link) => {
          link.toggleAttribute("data-current", link.getAttribute("data-target") === current);
        });
      };
      window.addEventListener("scroll", updateActive, { passive: true });
      updateActive();
    });
  </script>
</Base>
