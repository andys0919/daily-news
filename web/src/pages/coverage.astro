---
import Base from "../layouts/Base.astro";
import coverage from "../data/coverage.json";

interface Row { ticker: string; market: string; articles: number; reports: number }
const rows = (coverage.coverage ?? []) as Row[];
const tw = rows.filter((r) => r.market === "tw");
const us = rows.filter((r) => r.market === "us");
---
<Base title="覆蓋地圖 — 已建檔個股" active="coverage">
  <section class="hero">
    <div>
      <span class="live"><span class="live-dot"></span>{rows.length} tickers</span>
      <h1 class="mt-2">資料 <span class="accent">覆蓋</span> 地圖</h1>
      <p class="hero-sub">所有已被 daily-news 收錄至少一筆資料（新聞或財報）的個股。報告數越多代表官方財報深度越夠。</p>
    </div>
    <div class="hero-meta">
      <div>TW <span class="ts mono">{tw.length}</span></div>
      <div>US <span class="ts mono">{us.length}</span></div>
    </div>
  </section>

  <article class="glass bento mb-4">
    <header class="bento-head">
      <h2 class="bento-title">🇹🇼 台股 · {tw.length} 檔</h2>
      <span class="bento-link mono">含官方財報：{tw.filter((r) => r.reports > 0).length}</span>
    </header>
    <div class="cov-grid">
      {tw.slice(0, 120).map((r) => (
        <a href={`/stocks/${r.ticker}`} class="cov-cell">
          <span class="t">{r.ticker}</span>
          <span class="meta">
            {r.reports > 0 && (<><span class="dot r"></span>{r.reports}R </>)}
            {r.articles > 0 && (<><span class="dot a"></span>{r.articles}A</>)}
          </span>
        </a>
      ))}
    </div>
  </article>

  <article class="glass bento">
    <header class="bento-head">
      <h2 class="bento-title">🇺🇸 美股 · {us.length} 檔</h2>
      <span class="bento-link mono">含官方財報：{us.filter((r) => r.reports > 0).length}</span>
    </header>
    <div class="cov-grid">
      {us.slice(0, 120).map((r) => (
        <a href={`/stocks/${r.ticker}`} class="cov-cell">
          <span class="t">{r.ticker}</span>
          <span class="meta">
            {r.reports > 0 && (<><span class="dot r"></span>{r.reports}R </>)}
            {r.articles > 0 && (<><span class="dot a"></span>{r.articles}A</>)}
          </span>
        </a>
      ))}
    </div>
  </article>
</Base>
