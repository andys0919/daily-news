---
import Base from "../layouts/Base.astro";
import data from "../data/decisions.json";

interface Decision {
  date: string;
  ticker: string;
  action: string;
  thesis: string;
  size_pct?: number;
  follow_up?: string;
}
const decisions = (data.decisions ?? []) as unknown as Decision[];
---
<Base title="決策日誌 — Investment Dashboard" active="decisions">
  <section class="hero">
    <div>
      <span class="live"><span class="live-dot"></span>journal · {decisions.length} 筆</span>
      <h1 class="mt-2">決策 <span class="accent">日誌</span></h1>
      <p class="hero-sub">記錄論點與部位調整，回頭檢視 thesis 是否還成立。資料格式：<span class="mono">data/decisions.yaml</span>（自選欄位）。</p>
    </div>
  </section>

  {decisions.length === 0 ? (
    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">尚無紀錄</h2>
      </header>
      <p class="muted text-sm">
        建立 <span class="mono">data/decisions.yaml</span> 來開始記錄。範例：
      </p>
      <pre class="mono" style="margin-top:8px; padding:12px; background: var(--bg-880); border:1px solid var(--border-base); border-radius: 8px; font-size:11px; color: var(--fg-300); overflow-x:auto;">
- date: 2026-05-11
  ticker: NVDA
  action: trim
  size_pct: -10
  thesis: 估值偏高，先收 10%
  follow_up: 等 Q1 法說再評估</pre>
    </article>
  ) : (
    <div class="space-y-3">
      {decisions.map((d) => (
        <article class="glass bento">
          <div style="display:flex; align-items:baseline; gap:14px; flex-wrap:wrap;">
            <span class="mono ts">{d.date}</span>
            <a href={`/stocks/${d.ticker}`} class="chip-mini ticker mono">{d.ticker}</a>
            <span style="font-size:13px;">{d.action}{d.size_pct ? ` (${d.size_pct > 0 ? "+" : ""}${d.size_pct}%)` : ""}</span>
          </div>
          {d.thesis && <p style="margin-top:8px; font-size:13px; color: var(--fg-200); line-height:1.6;">論點：{d.thesis}</p>}
          {d.follow_up && <p class="muted text-xs" style="margin-top:4px;">追蹤：{d.follow_up}</p>}
        </article>
      ))}
    </div>
  )}
</Base>
