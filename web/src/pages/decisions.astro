---
import Base from "../layouts/Base.astro";
import data from "../data/decisions.json";

interface Decision {
  date: string; ticker: string; action: string; thesis: string;
  size_pct?: number; follow_up?: string;
}
const decisions = (data.decisions ?? []) as unknown as Decision[];
---
<Base title="日誌 — 投資 dashboard" active="decisions">
  <header class="page-h">
    <div class="eyebrow">journal · {decisions.length} 筆</div>
    <h1>決策 <span class="accent">日誌</span></h1>
    <p>
      手動記錄每次部位調整的論點與後續追蹤事項。建立 <span class="mono">data/decisions.yaml</span> 後會自動載入。
    </p>
  </header>

  <aside class="howto">
    <div class="howto-icon">i</div>
    <div>
      <p class="howto-title">為什麼要寫決策日誌</p>
      <p class="howto-body">
        投資決策只看當下都是 plausible；事後回顧才能分辨 <strong>對的判斷</strong> 與 <strong>對的結果</strong>。把進場 / 加減碼 / 出場時的論點寫下來，定期回看，可看出自己 thesis 在哪些情境會錯。<strong>不是必要功能</strong>——只是給願意做研究紀錄的人用。
      </p>
    </div>
  </aside>

  {decisions.length === 0 ? (
    <article class="glass bento">
      <header class="bento-head">
        <h2 class="bento-title">尚無紀錄</h2>
      </header>
      <p class="muted" style="font-size: var(--t-small);">
        建立 <span class="mono">data/decisions.yaml</span> 開始記錄。範例：
      </p>
      <pre class="mono" style="margin-top: var(--s-3); padding: var(--s-4); background: var(--bg-880); border: 1px solid var(--border-base); border-radius: 8px; font-size: var(--t-label); color: var(--fg-300); overflow-x: auto; line-height: 1.6;">- date: 2026-05-11
  ticker: NVDA
  action: trim
  size_pct: -10
  thesis: 估值偏高，先收 10%
  follow_up: 等 Q1 法說再評估</pre>
    </article>
  ) : (
    <div style="display: flex; flex-direction: column; gap: var(--s-3);">
      {decisions.map((d) => (
        <article class="glass bento">
          <div style="display: flex; align-items: baseline; gap: var(--s-3); flex-wrap: wrap;">
            <span class="mono" style="color: var(--fg-200); font-size: var(--t-small);">{d.date}</span>
            <a href={`/stocks/${d.ticker}/`} class="chip-mini ticker mono">{d.ticker}</a>
            <span style="font-size: var(--t-body);">{d.action}{d.size_pct ? ` (${d.size_pct > 0 ? "+" : ""}${d.size_pct}%)` : ""}</span>
          </div>
          {d.thesis && <p style="margin-top: var(--s-2); font-size: var(--t-body); color: var(--fg-200); line-height: 1.65;">論點：{d.thesis}</p>}
          {d.follow_up && <p class="muted" style="font-size: var(--t-small); margin-top: var(--s-1);">追蹤：{d.follow_up}</p>}
        </article>
      ))}
    </div>
  )}
</Base>
