---
import "../styles/global.css";

interface Props {
  title?: string;
}
const { title = "投資決策 Dashboard" } = Astro.props;
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#0a0c10" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body class="min-h-screen">
    <nav class="topnav">
      <div class="topnav-inner">
        <a href="/" class="brand">
          <span class="brand-dot"></span>
          <span class="brand-name">Daily-News</span>
          <span class="brand-meta">Investment Desk</span>
        </a>
        <div class="navlinks">
          <a href="/" class="navlink" data-active>總覽</a>
          <a href="/news" class="navlink">新聞</a>
          <a href="/calendar" class="navlink">月曆</a>
          <a href="/decisions" class="navlink">日誌</a>
        </div>
        <div class="topnav-meta">
          <kbd class="kbd">/</kbd>
          <span class="muted">search</span>
        </div>
      </div>
    </nav>
    <main class="page">
      <slot />
    </main>
    <footer class="page-footer">
      <span class="mono muted">build {new Date().toISOString().slice(0, 16).replace("T", " ")}Z</span>
      <span class="muted">·</span>
      <span class="muted">私人投資研究輔助，非投資建議</span>
    </footer>
  </body>
</html>
