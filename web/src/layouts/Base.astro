---
import "../styles/global.css";

interface Props {
  title?: string;
  active?: string;
}
const { title = "投資決策 Dashboard", active = "home" } = Astro.props;
const nav = [
  { id: "home", href: "/", label: "Guidance" },
  { id: "guidance", href: "/guidance", label: "Feed" },
  { id: "news", href: "/news", label: "新聞" },
  { id: "calendar", href: "/calendar", label: "事件" },
  { id: "decisions", href: "/decisions", label: "日誌" },
  { id: "explore", href: "/explore", label: "探索" },
];
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#0a0c10" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body class="min-h-screen">
    <nav class="topnav">
      <div class="topnav-inner">
        <a href="/" class="brand">
          <span class="brand-dot"></span>
          <span class="brand-name">Daily-News</span>
          <span class="brand-meta">Investment Desk</span>
        </a>
        <div class="navlinks">
          {nav.map((n) => (
            <a href={n.href} class="navlink" data-active={active === n.id ? "" : undefined}>{n.label}</a>
          ))}
        </div>
        <div class="topnav-meta">
          <kbd class="kbd">/</kbd>
          <span class="muted">search</span>
        </div>
      </div>
    </nav>
    <main class="page">
      <slot />
    </main>
    <footer class="page-footer">
      <span class="mono muted">build {new Date().toISOString().slice(0, 16).replace("T", " ")}Z</span>
      <span class="muted">·</span>
      <span class="muted">私人投資研究輔助，非投資建議</span>
    </footer>
  </body>
</html>
